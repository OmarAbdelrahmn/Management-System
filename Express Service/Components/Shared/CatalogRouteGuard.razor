@implements IDisposable
@inject SystemCatalogUiService Catalog
@inject NavigationManager Navigation
@inject ILogger<CatalogRouteGuard> Logger

@if (!checkedAccess)
{
    <section class="panel"><div class="panel-body">جارٍ التحقق من صلاحية الخدمة...</div></section>
}
else if (!isAllowed)
{
    <section class="panel">
        <div class="panel-heading"><i class="fa-solid @(accessCheckFailed ? "fa-triangle-exclamation" : "fa-lock")"></i><div><h2>@(accessCheckFailed ? "تعذر التحقق من صلاحية الخدمة" : "غير مصرح بالوصول")</h2><p>@(accessCheckFailed ? "حدث خلل مؤقت أثناء التحقق من الصلاحيات. أعد تحميل الصفحة أو حاول لاحقاً." : "لا تملك صلاحية فتح هذه الخدمة مباشرة.")</p></div></div>
    </section>
}
else
{
    @ChildContent
}

@code {
    [Parameter, EditorRequired] public RenderFragment? ChildContent { get; set; }

    private bool checkedAccess;
    private bool isAllowed = true;
    private bool accessCheckFailed;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        await CheckAccessAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args) => _ = InvokeAsync(CheckAccessAsync);

    private async Task CheckAccessAsync()
    {
        checkedAccess = false;
        accessCheckFailed = false;
        await InvokeAsync(StateHasChanged);
        var route = "/" + Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
        if (string.Equals(route, "/dashboard", StringComparison.OrdinalIgnoreCase))
        {
            isAllowed = true;
            checkedAccess = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            var access = await Catalog.GetRouteAccessAsync(route);
            isAllowed = access.IsAllowed;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to check catalog access for route {Route}.", route);
            isAllowed = false;
            accessCheckFailed = true;
        }
        checkedAccess = true;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}
