@page "/notifications/database"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject MessagingUiService Messaging

<h1 class="page-title">قاعدة بيانات الإشعارات</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-database"></i><div><h2>بحث الإشعارات</h2><p>عرض الإشعارات حسب الحالة والقناة ونص الإشعار مع متابعة المستلمين.</p></div><a class="primary" href="/notifications/manage">إشعار جديد</a></div>
    <div class="form-grid compact">
        <label>الحالة<select @bind="statusText"><option value="">الكل</option><option value="Active">فعالة</option><option value="Cancelled">ملغاة</option><option value="Expired">منتهية</option></select></label>
        <label>القناة<select @bind="channelText"><option value="">الكل</option><option value="Internal">داخلي</option><option value="Email">Email</option><option value="Sms">SMS</option><option value="Push">Push</option></select></label>
        <label class="span-2">كلمة بحث<input @bind="keyword" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="LoadAsync">بحث</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-bell"></i> الإشعارات</span></div>
    <table>
        <thead><tr><th>العنوان</th><th>القناة</th><th>الحالة</th><th>المنشئ</th><th>المستلمون</th><th>التسليم</th><th>التاريخ</th><th>إجراءات</th></tr></thead>
        <tbody>
            @foreach (var notification in notifications)
            {
                <tr>
                    <td>@notification.Title</td>
                    <td>@notification.Channel</td>
                    <td><span class="status">@notification.Status</span></td>
                    <td>@notification.CreatedByName</td>
                    <td>@notification.Recipients.Count</td>
                    <td>@DeliverySummary(notification)</td>
                    <td>@notification.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td><button class="secondary" @onclick="() => SelectNotification(notification)">تفاصيل</button></td>
                </tr>
            }
        </tbody>
    </table>
</section>

@if (selectedNotification is not null)
{
    <section class="panel">
        <div class="panel-heading">
            <i class="fa-solid fa-list-check"></i>
            <div>
                <h2>متابعة المستلمين: @selectedNotification.Title</h2>
                <p>@selectedNotification.Body</p>
            </div>
            <a class="secondary" href="/notifications/cancel">إلغاء إشعار</a>
        </div>
        <div class="form-grid compact">
            <label>القناة<input value="@selectedNotification.Channel" readonly /></label>
            <label>الحالة<input value="@selectedNotification.Status" readonly /></label>
            <label>موعد الإرسال<input value="@(selectedNotification.ScheduledAt?.ToString("yyyy-MM-dd HH:mm") ?? "فوري")" readonly /></label>
            <label>سبب الإلغاء<input value="@(selectedNotification.CancellationReason ?? "-")" readonly /></label>
        </div>
    </section>

    <section class="table-section">
        <div class="table-title"><span><i class="fa-solid fa-users-viewfinder"></i> حالة المستلمين</span></div>
        <table>
            <thead><tr><th>المستلم</th><th>القراءة</th><th>التسليم</th><th>المحاولات</th><th>آخر محاولة</th><th>تم التسليم</th><th>مرجع المزود</th><th>الخطأ</th><th>إجراءات</th></tr></thead>
            <tbody>
                @foreach (var recipient in selectedNotification.Recipients)
                {
                    <tr>
                        <td>@recipient.RecipientName</td>
                        <td>@(recipient.IsRead ? $"مقروء {recipient.ReadAt:yyyy-MM-dd HH:mm}" : "غير مقروء")</td>
                        <td><span class="status">@recipient.DeliveryStatus</span></td>
                        <td>@recipient.DeliveryAttempts</td>
                        <td>@(recipient.LastAttemptedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                        <td>@(recipient.DeliveredAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                        <td>@(recipient.ProviderReference ?? "-")</td>
                        <td>@(recipient.LastDeliveryError ?? "-")</td>
                        <td>
                            <button class="secondary" @onclick="() => ChooseRecipient(recipient.Id)">تحديث التسليم</button>
                            <button class="secondary" @onclick="() => MarkReadAsync(recipient.Id)">تعليم كمقروء</button>
                            <button class="secondary" @onclick="() => RetryAsync(recipient.Id)">إعادة إرسال</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    @if (selectedNotification.Recipients.Any())
    {
        <section class="panel">
            <div class="panel-heading"><i class="fa-solid fa-truck-fast"></i><div><h2>تحديث حالة التسليم</h2><p>يسجل نتيجة المحاولة للمستلم ويضيفها في سجل القنوات.</p></div></div>
            <div class="form-grid compact">
                <label>المستلم<select @bind="deliveryRecipientId">@foreach (var recipient in selectedNotification.Recipients){<option value="@recipient.Id">@recipient.RecipientName</option>}</select></label>
                <label>الحالة<select @bind="deliveryStatus"><option value="@ChannelDeliveryStatus.Pending">قيد الإرسال</option><option value="@ChannelDeliveryStatus.Sent">تم الإرسال</option><option value="@ChannelDeliveryStatus.Failed">فشل</option><option value="@ChannelDeliveryStatus.Cancelled">ملغى</option></select></label>
                <label>مرجع المزود<input @bind="providerReference" /></label>
                <label class="span-2">ملاحظة الخطأ<textarea @bind="deliveryError"></textarea></label>
            </div>
            <div class="actions-row"><button class="primary" @onclick="SaveDeliveryAsync">حفظ حالة التسليم</button></div>
        </section>
    }
}

@code {
    private List<NotificationResponse> notifications = [];
    private NotificationResponse? selectedNotification;
    private string statusText = string.Empty;
    private string channelText = string.Empty;
    private string keyword = string.Empty;
    private int deliveryRecipientId;
    private ChannelDeliveryStatus deliveryStatus = ChannelDeliveryStatus.Sent;
    private string providerReference = string.Empty;
    private string deliveryError = string.Empty;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var status = Enum.TryParse<NotificationStatus>(statusText, out var parsed) ? parsed : (NotificationStatus?)null;
        var channel = Enum.TryParse<MessageChannel>(channelText, out var parsedChannel) ? parsedChannel : (MessageChannel?)null;
        var selectedId = selectedNotification?.Id;
        notifications = await Messaging.GetNotificationsAsync(status, channel, keyword);
        selectedNotification = selectedId.HasValue
            ? notifications.FirstOrDefault(x => x.Id == selectedId.Value)
            : notifications.FirstOrDefault();
        deliveryRecipientId = selectedNotification?.Recipients.FirstOrDefault()?.Id ?? 0;
    }

    private void SelectNotification(NotificationResponse notification)
    {
        selectedNotification = notification;
        deliveryRecipientId = notification.Recipients.FirstOrDefault()?.Id ?? 0;
        providerReference = string.Empty;
        deliveryError = string.Empty;
    }

    private void ChooseRecipient(int recipientId)
    {
        deliveryRecipientId = recipientId;
        var recipient = selectedNotification?.Recipients.FirstOrDefault(x => x.Id == recipientId);
        if (recipient is not null && Enum.TryParse<ChannelDeliveryStatus>(recipient.DeliveryStatus, out var parsedStatus))
            deliveryStatus = parsedStatus;

        providerReference = recipient?.ProviderReference ?? string.Empty;
        deliveryError = recipient?.LastDeliveryError ?? string.Empty;
    }

    private async Task SaveDeliveryAsync()
    {
        if (deliveryRecipientId == 0)
        {
            success = false;
            message = "اختر مستلماً قبل تحديث حالة التسليم.";
            return;
        }

        var result = await Messaging.RecordNotificationDeliveryAsync(deliveryRecipientId, new UpdateNotificationDeliveryRequest(deliveryStatus, providerReference, deliveryError));
        await ApplyResultAsync(result);
        providerReference = string.Empty;
        deliveryError = string.Empty;
    }

    private async Task MarkReadAsync(int recipientId)
    {
        var result = await Messaging.MarkNotificationRecipientReadAsync(recipientId);
        await ApplyResultAsync(result);
    }

    private async Task RetryAsync(int recipientId)
    {
        var result = await Messaging.RetryNotificationRecipientAsync(recipientId);
        await ApplyResultAsync(result);
    }

    private async Task ApplyResultAsync((bool Success, string Message) result)
    {
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private static string DeliverySummary(NotificationResponse notification)
    {
        var sent = notification.Recipients.Count(x => x.DeliveryStatus == ChannelDeliveryStatus.Sent.ToString());
        var pending = notification.Recipients.Count(x => x.DeliveryStatus == ChannelDeliveryStatus.Pending.ToString());
        var failed = notification.Recipients.Count(x => x.DeliveryStatus == ChannelDeliveryStatus.Failed.ToString());
        return $"{sent} مرسل / {pending} معلق / {failed} فشل";
    }
}
