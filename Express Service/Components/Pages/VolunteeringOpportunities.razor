@page "/volunteering/opportunities"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject VolunteeringUiService Volunteering

<h1 class="page-title">إدارة الفرص التطوعية</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-hand-holding-heart"></i><div><h2>فرصة تطوعية</h2><p>إدارة الفرص، الإجراءات، التقارير، طلبات التطوع، المتطوعين، المهام، والحضور.</p></div></div>
    <div class="form-grid compact">
        <label>رقم الفرصة<input @bind="opportunityNumber" /></label>
        <label>العنوان<input @bind="title" /></label>
        <label>الإدارة<input @bind="department" /></label>
        <label>تاريخ البداية<input type="date" @bind="startDate" /></label>
        <label>تاريخ النهاية<input type="date" @bind="endDate" /></label>
        <label>المقاعد<input type="number" @bind="seats" /></label>
        <label>الحالة<select @bind="opportunityStatus"><option value="@VolunteerOpportunityStatus.Draft">مسودة</option><option value="@VolunteerOpportunityStatus.Open">مفتوحة</option><option value="@VolunteerOpportunityStatus.InProgress">قيد التنفيذ</option><option value="@VolunteerOpportunityStatus.Completed">مكتملة</option><option value="@VolunteerOpportunityStatus.Cancelled">ملغاة</option></select></label>
        <label class="span-2">الوصف<input @bind="description" /></label>
        <label class="span-2">إجراءات الفرصة<input @bind="procedureNotes" /></label>
        <label class="span-2">تقرير الفرصة<input @bind="reportSummary" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveOpportunityAsync">حفظ الفرصة</button><button class="secondary" @onclick="LoadOpenOpportunitiesAsync">المفتوحة</button><button class="secondary" @onclick="LoadCompletedOpportunitiesAsync">المكتملة</button><button class="secondary" @onclick="SaveReportForFirstAsync">حفظ تقرير لأول فرصة</button></div>
</section>

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-list-check"></i><div><h2>مهام وحضور الفرصة</h2><p>إدارة مهام الفرص وسجلات حضور المتطوعين.</p></div></div>
    <div class="form-grid compact">
        <label>الفرصة<select @bind="selectedOpportunityId"><option value="0">اختر فرصة</option>@foreach (var item in opportunities){<option value="@item.Id">@item.OpportunityNumber - @item.Title</option>}</select></label>
        <label>عنوان المهمة<input @bind="taskTitle" /></label>
        <label>المسند إليه<input @bind="assignedTo" /></label>
        <label>استحقاق المهمة<input type="date" @bind="taskDueDate" /></label>
        <label>حالة المهمة<select @bind="taskStatus"><option value="@VolunteerTaskStatus.Open">مفتوحة</option><option value="@VolunteerTaskStatus.InProgress">قيد التنفيذ</option><option value="@VolunteerTaskStatus.Completed">مكتملة</option><option value="@VolunteerTaskStatus.Cancelled">ملغاة</option></select></label>
        <label>المتطوع<select @bind="selectedVolunteerId"><option value="0">اختر متطوع</option>@foreach (var user in users){<option value="@user.Id">@user.FullName</option>}</select></label>
        <label>تاريخ الحضور<input type="date" @bind="attendanceDate" /></label>
        <label>الساعات<input type="number" step="0.5" @bind="hours" /></label>
        <label>حالة الحضور<select @bind="attendanceStatus"><option value="@VolunteerAttendanceStatus.Present">حاضر</option><option value="@VolunteerAttendanceStatus.Absent">غائب</option><option value="@VolunteerAttendanceStatus.Excused">معتذر</option></select></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveTaskAsync">حفظ مهمة</button><button class="secondary" @onclick="SaveAttendanceAsync">حفظ حضور</button><button class="secondary" @onclick="LoadOpenTasksAsync">المهام المفتوحة</button><button class="secondary" @onclick="LoadAsync">تحديث</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-database"></i> الفرص التطوعية</span></div>
    <table>
        <thead><tr><th>الفرصة</th><th>الفترة</th><th>المقاعد</th><th>الحالة</th><th>الإجراءات والتقارير</th><th>الأرقام</th></tr></thead>
        <tbody>
            @foreach (var item in opportunities)
            {
                <tr><td>@item.OpportunityNumber<br />@item.Title<br />@item.Department</td><td>@item.StartDate.ToString("yyyy-MM-dd")<br />@item.EndDate?.ToString("yyyy-MM-dd")</td><td>@item.Seats</td><td>@item.Status</td><td>@item.ProcedureNotes<br />@item.ReportSummary</td><td>@item.RequestsCount طلب<br />@item.TasksCount مهمة<br />@item.AttendanceCount حضور</td></tr>
            }
        </tbody>
    </table>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-list-check"></i> مهام الفرص</span></div>
    <table>
        <thead><tr><th>الفرصة</th><th>المهمة</th><th>المسؤول</th><th>الاستحقاق</th><th>الحالة</th></tr></thead>
        <tbody>
            @foreach (var item in tasks)
            {
                <tr><td>@item.OpportunityTitle</td><td>@item.Title</td><td>@item.AssignedTo</td><td>@item.DueDate?.ToString("yyyy-MM-dd")</td><td>@item.Status<br />@item.Notes</td></tr>
            }
        </tbody>
    </table>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-clock"></i> سجلات الحضور</span></div>
    <table>
        <thead><tr><th>الفرصة</th><th>المتطوع</th><th>التاريخ</th><th>الساعات</th><th>الحالة</th></tr></thead>
        <tbody>
            @foreach (var item in attendance)
            {
                <tr><td>@item.OpportunityTitle</td><td>@item.VolunteerName</td><td>@item.AttendanceDate.ToString("yyyy-MM-dd")</td><td>@item.Hours</td><td>@item.Status<br />@item.Notes</td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<VolunteerOpportunityResponse> opportunities = [];
    private List<VolunteerOpportunityTaskResponse> tasks = [];
    private List<VolunteerAttendanceResponse> attendance = [];
    private List<VolunteerUserResponse> users = [];
    private string opportunityNumber = $"VO-{DateTime.UtcNow:yyyyMMddHHmm}";
    private string title = string.Empty;
    private string? description;
    private string? department;
    private DateTime startDate = DateTime.UtcNow.AddHours(3).Date;
    private DateTime? endDate = DateTime.UtcNow.AddHours(3).Date.AddDays(7);
    private int seats = 10;
    private VolunteerOpportunityStatus opportunityStatus = VolunteerOpportunityStatus.Open;
    private string? procedureNotes;
    private string? reportSummary;
    private int selectedOpportunityId;
    private string taskTitle = string.Empty;
    private string? assignedTo;
    private DateTime? taskDueDate = DateTime.UtcNow.AddHours(3).Date.AddDays(3);
    private VolunteerTaskStatus taskStatus = VolunteerTaskStatus.Open;
    private int selectedVolunteerId;
    private DateTime attendanceDate = DateTime.UtcNow.AddHours(3).Date;
    private decimal hours = 1;
    private VolunteerAttendanceStatus attendanceStatus = VolunteerAttendanceStatus.Present;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync(){ opportunities = await Volunteering.GetOpportunitiesAsync(); tasks = await Volunteering.GetTasksAsync(); attendance = await Volunteering.GetAttendanceAsync(); users = await Volunteering.GetUsersAsync(VolunteerUserStatus.Active); }
    private async Task LoadOpenOpportunitiesAsync() => opportunities = await Volunteering.GetOpportunitiesAsync(VolunteerOpportunityStatus.Open);
    private async Task LoadCompletedOpportunitiesAsync() => opportunities = await Volunteering.GetOpportunitiesAsync(VolunteerOpportunityStatus.Completed);
    private async Task LoadOpenTasksAsync() => tasks = await Volunteering.GetTasksAsync(status: VolunteerTaskStatus.Open);
    private async Task SaveOpportunityAsync(){ var result = await Volunteering.SaveOpportunityAsync(null, new SaveVolunteerOpportunityRequest(opportunityNumber, title, description, department, startDate, endDate, seats, opportunityStatus, procedureNotes, reportSummary)); success = result.Success; message = result.Message; if (success) opportunityNumber = $"VO-{DateTime.UtcNow:yyyyMMddHHmmss}"; await LoadAsync(); }
    private async Task SaveReportForFirstAsync(){ var item = opportunities.FirstOrDefault(); if (item is null){ success = false; message = "لا توجد فرصة لحفظ تقريرها."; return; } var result = await Volunteering.SaveOpportunityReportAsync(item.Id, new SaveVolunteerOpportunityReportRequest(procedureNotes, reportSummary, opportunityStatus)); success = result.Success; message = result.Message; await LoadAsync(); }
    private async Task SaveTaskAsync(){ var result = await Volunteering.SaveTaskAsync(null, new SaveVolunteerOpportunityTaskRequest(selectedOpportunityId, taskTitle, assignedTo, taskDueDate, taskStatus, procedureNotes)); success = result.Success; message = result.Message; await LoadAsync(); }
    private async Task SaveAttendanceAsync(){ var result = await Volunteering.SaveAttendanceAsync(null, new SaveVolunteerAttendanceRequest(selectedOpportunityId, selectedVolunteerId, attendanceDate, hours, attendanceStatus, reportSummary)); success = result.Success; message = result.Message; await LoadAsync(); }
}
