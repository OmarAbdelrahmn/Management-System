@page "/hr/admin-requests"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject HumanResourceUiService HR

<h1 class="page-title">الطلبات الإدارية</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-file-signature"></i><div><h2>طلب إداري</h2><p>إنشاء واعتماد ومتابعة الطلبات الإدارية.</p></div></div>
    <div class="form-grid">
        <label>الموظف<select @bind="employeeIdText"><option value="">بدون موظف محدد</option>@foreach (var employee in employees){<option value="@employee.Id">@employee.FullName</option>}</select></label>
        <label>نوع الطلب<input @bind="requestType" /></label>
        <label class="span-2">العنوان<input @bind="title" /></label>
        <label class="span-2">التفاصيل<textarea @bind="details"></textarea></label>
        <label class="span-2">ملاحظة القرار<input @bind="decisionNotes" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveAsync">إنشاء الطلب</button><button class="secondary" @onclick="LoadAsync">تحديث</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-list-check"></i> الطلبات</span></div>
    <table>
        <thead><tr><th>الموظف</th><th>النوع</th><th>العنوان</th><th>الحالة</th><th>قرار</th><th>السجل</th></tr></thead>
        <tbody>
            @foreach (var item in requests)
            {
                <tr><td>@item.EmployeeName</td><td>@item.RequestType</td><td>@item.Title</td><td><span class="status">@item.Status</span></td><td>@if (item.Status == "Pending"){<button class="secondary" @onclick="() => DecideAsync(item.Id, HumanResourceRequestStatus.Approved)">اعتماد</button><button class="danger" @onclick="() => DecideAsync(item.Id, HumanResourceRequestStatus.Rejected)">رفض</button><button class="danger" @onclick="() => DecideAsync(item.Id, HumanResourceRequestStatus.Cancelled)">إلغاء</button>} else if (item.Status == "Approved"){<button class="primary" @onclick="() => DecideAsync(item.Id, HumanResourceRequestStatus.Completed)">إكمال</button><button class="danger" @onclick="() => DecideAsync(item.Id, HumanResourceRequestStatus.Cancelled)">إلغاء</button>}</td><td><button class="secondary" @onclick="() => LoadActivityAsync(item)">السجل</button></td></tr>
            }
        </tbody>
    </table>
</section>

@if (activities.Count > 0)
{
    <section class="table-section" style="margin-top:14px">
        <div class="table-title"><span><i class="fa-solid fa-clock-rotate-left"></i> سجل @activityTitle</span></div>
        <table>
            <thead><tr><th>الوقت</th><th>الإجراء</th><th>من</th><th>إلى</th><th>ملاحظات</th></tr></thead>
            <tbody>
                @foreach (var item in activities)
                {
                    <tr><td>@item.OccurredAt.ToString("yyyy-MM-dd HH:mm")</td><td>@item.Action</td><td>@item.FromStatus</td><td>@item.ToStatus</td><td>@item.Notes</td></tr>
                }
            </tbody>
        </table>
    </section>
}

@code {
    private List<EmployeeResponse> employees = [];
    private List<EmployeeAdministrativeRequestResponse> requests = [];
    private List<HumanResourceActivityResponse> activities = [];
    private string? activityTitle;
    private string employeeIdText = string.Empty;
    private string requestType = "طلب إداري";
    private string title = string.Empty;
    private string details = string.Empty;
    private string? decisionNotes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        employees = await HR.SearchEmployeesAsync(null, null, null, null);
        await LoadAsync();
    }

    private async Task LoadAsync() => requests = await HR.GetAdministrativeRequestsAsync();

    private async Task SaveAsync()
    {
        var employeeId = int.TryParse(employeeIdText, out var value) ? value : (int?)null;
        var result = await HR.CreateAdministrativeRequestAsync(new CreateEmployeeAdministrativeRequest(employeeId, requestType, title, details));
        success = result.Success;
        message = result.Message;
        if (success)
        {
            title = string.Empty;
            details = string.Empty;
            await LoadAsync();
        }
    }

    private async Task DecideAsync(int id, HumanResourceRequestStatus status)
    {
        var result = await HR.DecideAdministrativeRequestAsync(id, status, decisionNotes);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private async Task LoadActivityAsync(EmployeeAdministrativeRequestResponse item)
    {
        activityTitle = item.Title;
        activities = await HR.GetActivitiesAsync(HumanResourceActivityEntityType.AdministrativeRequest, item.Id);
    }
}
