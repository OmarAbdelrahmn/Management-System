@page "/programs-projects/approvals"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject ProgramsProjectsUiService ProgramsProjects

<h1 class="page-title">اعتمادات مقترحات البرامج</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-stamp"></i><div><h2>@(editingApprovalId.HasValue ? "تعديل طلب اعتماد" : "طلب اعتماد")</h2><p>تسجيل وتصحيح اعتماد فكرة أو فريق أو ميزانية أو خطة تسويق.</p></div></div>
    <div class="form-grid compact">
        <label>مقترح البرنامج<select @bind="ideaIdText"><option value="">بدون ربط</option>@foreach (var idea in ideas){<option value="@idea.Id">@idea.Title</option>}</select></label>
        <label>نوع الاعتماد<select @bind="approvalType"><option>Idea</option><option>Team</option><option>Budget</option><option>Marketing</option><option>Completion</option></select></label>
        <label class="span-2">العنوان<input @bind="title" /></label>
    </div>
    <div class="actions-row">
        <button class="primary" @onclick="SaveAsync">@(editingApprovalId.HasValue ? "حفظ التعديل" : "حفظ الاعتماد")</button>
        @if (editingApprovalId.HasValue)
        {
            <button class="secondary" @onclick="ResetForm">إلغاء التعديل</button>
        }
    </div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-filter"></i><div><h2>قرارات الاعتماد</h2><p>مراجعة السجل واعتماد أو رفض الطلبات.</p></div></div>
    <div class="form-grid compact">
        <label>الحالة<select @bind="statusText"><option value="">الكل</option><option value="Pending">بانتظار القرار</option><option value="Approved">معتمد</option><option value="Rejected">مرفوض</option><option value="Completed">مكتمل</option><option value="Cancelled">ملغى</option></select></label>
        <label>ملاحظة القرار<input @bind="decisionNotes" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="LoadAsync">تحديث</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-clock-rotate-left"></i> سجل الاعتمادات</span></div>
    <table>
        <thead><tr><th>العنوان</th><th>النوع</th><th>المقترح</th><th>الحالة</th><th>الملاحظات</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var approval in approvals)
            {
                <tr>
                    <td>@approval.Title</td>
                    <td>@approval.ApprovalType</td>
                    <td>@approval.ProgramIdeaTitle</td>
                    <td><span class="status">@approval.Status</span></td>
                    <td>@approval.DecisionNotes</td>
                    <td>
                        <button class="secondary" @onclick="@(() => Edit(approval))">تعديل</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(approval.Id, ProgramApprovalStatus.Approved))">اعتماد</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(approval.Id, ProgramApprovalStatus.Rejected))">رفض</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(approval.Id, ProgramApprovalStatus.Completed))">إكمال</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(approval.Id, ProgramApprovalStatus.Cancelled))">إلغاء</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<ProgramIdeaResponse> ideas = [];
    private List<ProgramApprovalResponse> approvals = [];
    private string ideaIdText = string.Empty;
    private string approvalType = "Idea";
    private string title = string.Empty;
    private int? editingApprovalId;
    private string statusText = string.Empty;
    private string? decisionNotes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        ideas = await ProgramsProjects.GetIdeasAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var parsedStatus = Enum.TryParse<ProgramApprovalStatus>(statusText, out var value) ? value : (ProgramApprovalStatus?)null;
        approvals = await ProgramsProjects.GetApprovalsAsync(parsedStatus);
    }

    private async Task SaveAsync()
    {
        var ideaId = int.TryParse(ideaIdText, out var value) ? value : (int?)null;
        var result = await ProgramsProjects.SaveApprovalAsync(editingApprovalId, new SaveProgramApprovalRequest(ideaId, approvalType, title));
        success = result.Success;
        message = result.Message;
        if (success)
            ResetForm();
        await LoadAsync();
    }

    private async Task DecideAsync(int id, ProgramApprovalStatus status)
    {
        var result = await ProgramsProjects.DecideApprovalAsync(id, status, decisionNotes);
        success = result.Success;
        message = result.Message;
        ideas = await ProgramsProjects.GetIdeasAsync();
        await LoadAsync();
    }

    private void Edit(ProgramApprovalResponse approval)
    {
        editingApprovalId = approval.Id;
        ideaIdText = approval.ProgramIdeaId?.ToString() ?? string.Empty;
        approvalType = approval.ApprovalType;
        title = approval.Title;
    }

    private void ResetForm()
    {
        editingApprovalId = null;
        ideaIdText = string.Empty;
        approvalType = "Idea";
        title = string.Empty;
    }
}
