@page "/admin/roles"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject AdminUiService Admin

<h1 class="page-title">الأدوار</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-user-shield"></i><div><h2>@(editingRoleId is null ? "دور جديد" : "تعديل الدور")</h2><p>الأدوار تستخدم في حماية الصفحات والـ API.</p></div></div>
    <div class="form-grid">
        <label>اسم الدور<input @bind="roleName" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveAsync">@(editingRoleId is null ? "إنشاء الدور" : "حفظ التعديل")</button>@if (editingRoleId is not null){<button class="secondary" @onclick="ResetForm">إلغاء</button>}</div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-id-badge"></i> الأدوار الحالية</span></div>
    <table>
        <thead><tr><th>المعرف</th><th>الدور</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var role in roles)
            {
                <tr><td>@role.Id</td><td>@role.Name</td><td><button class="secondary" @onclick="() => Edit(role)">تعديل</button> <button class="danger" @onclick="() => DeleteAsync(role.Id)">حذف</button></td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<RoleResponse> roles = [];
    private string? editingRoleId;
    private string roleName = string.Empty;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => roles = await Admin.GetRolesAsync();

    private async Task SaveAsync()
    {
        var result = editingRoleId is null
            ? await Admin.CreateRoleAsync(roleName)
            : await Admin.UpdateRoleAsync(editingRoleId, roleName);
        success = result.Success;
        message = result.Message;
        if (success)
            ResetForm();
        roles = await Admin.GetRolesAsync();
    }

    private void Edit(RoleResponse role)
    {
        editingRoleId = role.Id;
        roleName = role.Name;
    }

    private async Task DeleteAsync(string id)
    {
        var result = await Admin.DeleteRoleAsync(id);
        success = result.Success;
        message = result.Message;
        if (editingRoleId == id)
            ResetForm();
        roles = await Admin.GetRolesAsync();
    }

    private void ResetForm()
    {
        editingRoleId = null;
        roleName = string.Empty;
    }
}
