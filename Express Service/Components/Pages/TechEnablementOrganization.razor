@page "/tech-enablement/organization"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject TechEnablementUiService Tech

<h1 class="page-title">إدارة الهيكل التنظيمي</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-sitemap"></i><div><h2>تعيين تنظيمي</h2><p>الهيكل الإداري، المناصب الاعتبارية، اللجان، التواقيع، ودورات الهيكل الإداري.</p></div></div>
    <div class="form-grid compact">
        <label>الوحدة<input @bind="unitName" /></label>
        <label>المكلف<input @bind="assigneeName" /></label>
        <label>النوع<select @bind="assignmentType"><option value="@OrganizationAssignmentType.Position">منصب</option><option value="@OrganizationAssignmentType.Committee">لجنة</option><option value="@OrganizationAssignmentType.Signature">توقيع</option><option value="@OrganizationAssignmentType.Cycle">دورة هيكل</option></select></label>
        <label>المسمى<input @bind="roleTitle" /></label>
        <label>من<input type="date" @bind="effectiveFrom" /></label>
        <label>إلى<input type="date" @bind="effectiveTo" /></label>
        <label>نشط<input type="checkbox" @bind="isActive" /></label>
        <label class="span-2">ملاحظات<input @bind="notes" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveAsync">حفظ التعيين</button><button class="secondary" @onclick="LoadActiveAsync">النشطة</button><button class="secondary" @onclick="LoadCommitteesAsync">اللجان</button><button class="secondary" @onclick="LoadAsync">كل التعيينات</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-database"></i> تعيينات الهيكل</span></div>
    <table>
        <thead><tr><th>الوحدة</th><th>المكلف</th><th>النوع</th><th>الفترة</th><th>الحالة</th></tr></thead>
        <tbody>
            @foreach (var item in assignments)
            {
                <tr><td>@item.UnitName<br />@item.RoleTitle</td><td>@item.AssigneeName</td><td>@item.AssignmentType</td><td>@item.EffectiveFrom.ToString("yyyy-MM-dd")<br />@item.EffectiveTo?.ToString("yyyy-MM-dd")</td><td>@(item.IsActive ? "نشط" : "غير نشط")<br />@item.Notes</td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<OrganizationAssignmentResponse> assignments = [];
    private string unitName = string.Empty;
    private string assigneeName = string.Empty;
    private OrganizationAssignmentType assignmentType = OrganizationAssignmentType.Position;
    private string? roleTitle;
    private DateTime effectiveFrom = DateTime.UtcNow.AddHours(3).Date;
    private DateTime? effectiveTo;
    private bool isActive = true;
    private string? notes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync() => assignments = await Tech.GetOrganizationAssignmentsAsync();
    private async Task LoadActiveAsync() => assignments = await Tech.GetOrganizationAssignmentsAsync(isActive: true);
    private async Task LoadCommitteesAsync() => assignments = await Tech.GetOrganizationAssignmentsAsync(OrganizationAssignmentType.Committee);
    private async Task SaveAsync(){ var result = await Tech.SaveOrganizationAssignmentAsync(null, new SaveOrganizationAssignmentRequest(unitName, assigneeName, assignmentType, roleTitle, effectiveFrom, effectiveTo, isActive, notes)); success = result.Success; message = result.Message; await LoadAsync(); }
}
