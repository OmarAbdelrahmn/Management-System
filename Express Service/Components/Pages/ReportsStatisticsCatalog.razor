@page "/reports-statistics/catalog"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject ReportsStatisticsUiService Reports

<h1 class="page-title">تقارير النظام</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-file-export"></i><div><h2>توليد تقرير</h2><p>اختيار تقرير من الكتالوج وتسجيل تشغيل التقرير مع عدد السجلات.</p></div></div>
    <div class="form-grid compact">
        <label>التقرير<select @bind="selectedKey">@foreach (var definition in definitions){<option value="@definition.Key">@definition.NameAr</option>}</select></label>
        <label>صيغة التصدير<select @bind="exportFormat"><option value="Csv">CSV</option><option value="Tsv">TSV</option><option value="Json">JSON</option><option value="Xlsx">XLSX</option><option value="Pdf">PDF</option></select></label>
        <label>طالب التقرير<input @bind="requestedBy" /></label>
        <label>أرشفة قبل تاريخ<input type="date" @bind="archiveBefore" /></label>
        <label class="span-2">الفلاتر JSON<input @bind="filtersJson" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="GenerateAsync">توليد التقرير</button><button class="secondary" @onclick="ExportAsync">تصدير @exportFormat</button><button class="secondary" onclick="window.print()">طباعة الشاشة</button><button class="secondary" @onclick="ArchiveSelectedRunsAsync">أرشفة تشغيلات التقرير</button><button class="secondary" @onclick="LoadArchivedRunsAsync">عرض المؤرشف</button></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-sliders"></i><div><h2>@(editingDefinitionId.HasValue ? "تعديل تعريف تقرير" : "تعريف تقرير")</h2><p>إضافة أو تعديل التقارير وتفعيلها أو إيقافها من الكتالوج.</p></div></div>
    <div class="form-grid compact">
        <label>المفتاح<input @bind="definitionKey" /></label>
        <label>الاسم العربي<input @bind="definitionNameAr" /></label>
        <label>النوع<select @bind="definitionKind"><option value="@SystemReportKind.Report">تقرير</option><option value="@SystemReportKind.Statistic">إحصائية</option></select></label>
        <label>النطاق<input @bind="definitionSourceDomain" /></label>
        <label class="check-row"><input type="checkbox" @bind="definitionIsActive" /> التعريف فعال</label>
    </div>
    <div class="actions-row">
        <button class="primary" @onclick="SaveDefinitionAsync">@(editingDefinitionId.HasValue ? "حفظ التعديل" : "حفظ التعريف")</button>
        @if (editingDefinitionId.HasValue)
        {
            <button class="secondary" @onclick="ResetDefinitionForm">إلغاء التعديل</button>
        }
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(exportContent))
{
    <section class="panel" style="margin-top:14px">
        <div class="panel-heading"><i class="fa-solid fa-file-csv"></i><div><h2>معاينة التصدير</h2><p>@exportFileName</p></div></div>
        <textarea class="span-2" readonly rows="8" style="width:100%;direction:ltr">@exportContent</textarea>
    </section>
}
@if (!string.IsNullOrWhiteSpace(downloadHref))
{
    <section class="panel" style="margin-top:14px"><div class="panel-body"><a class="primary" href="@downloadHref" download="@exportFileName">تنزيل @exportFileName</a></div></section>
}

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-list"></i> تقارير النظام</span></div>
    <table>
        <thead><tr><th>التقرير</th><th>النطاق</th><th>الحالة</th><th>آخر توليد</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var definition in definitions)
            {
                <tr>
                    <td>@definition.NameAr<br />@definition.Key</td>
                    <td>@definition.SourceDomain</td>
                    <td><span class="status">@(definition.IsActive ? "فعال" : "موقوف")</span></td>
                    <td>@definition.LastGeneratedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <button class="secondary" @onclick="@(() => EditDefinition(definition))">تعديل</button>
                        <button class="secondary" @onclick="@(() => ToggleDefinitionAsync(definition))">@(definition.IsActive ? "إيقاف" : "تفعيل")</button>
                        <button class="secondary" @onclick="@(() => SelectAndGenerateAsync(definition.Key))">توليد</button>
                        <button class="secondary" @onclick="@(() => SelectAndExportAsync(definition.Key))">تصدير</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="table-section" style="margin-top:14px">
    <div class="table-title"><span><i class="fa-solid fa-clock-rotate-left"></i> سجل التشغيل</span></div>
    <table>
        <thead><tr><th>التقرير</th><th>الصيغة</th><th>السجلات</th><th>الحالة</th><th>التاريخ</th><th>الأرشيف</th></tr></thead>
        <tbody>
            @foreach (var run in runs)
            {
                <tr><td>@run.ReportName<br />@run.ReportKey</td><td>@run.Format</td><td>@run.RowCount</td><td>@run.Status</td><td>@run.GeneratedAt.ToString("yyyy-MM-dd HH:mm")</td><td>@if (run.HasArchivedExport) { <a class="secondary small" href="@($"/api/ReportsStatistics/runs/{run.Id}/archive")">تنزيل</a> }</td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<SystemReportDefinitionResponse> definitions = [];
    private List<SystemReportRunResponse> runs = [];
    private string selectedKey = string.Empty;
    private string format = "Table";
    private string exportFormat = "Csv";
    private string? requestedBy;
    private string? filtersJson = "{}";
    private string? exportContent;
    private string? exportFileName;
    private string? downloadHref;
    private DateTime archiveBefore = DateTime.UtcNow.AddHours(3).Date;
    private int? editingDefinitionId;
    private string definitionKey = string.Empty;
    private string definitionNameAr = string.Empty;
    private SystemReportKind definitionKind = SystemReportKind.Report;
    private string definitionSourceDomain = string.Empty;
    private bool definitionIsActive = true;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync(){ definitions = await Reports.GetDefinitionsAsync(SystemReportKind.Report); runs = await Reports.GetRunsAsync(); selectedKey = string.IsNullOrWhiteSpace(selectedKey) ? definitions.FirstOrDefault()?.Key ?? string.Empty : selectedKey; }
    private async Task GenerateAsync(){ var result = await Reports.GenerateReportAsync(new GenerateSystemReportRequest(selectedKey, format, filtersJson, requestedBy)); success = result.Success; message = result.Message; await LoadAsync(); }
    private async Task ExportAsync()
    {
        var result = await Reports.ExportReportContentAsync(new GenerateSystemReportRequest(selectedKey, exportFormat, filtersJson, requestedBy));
        success = result.Success;
        message = result.Message;
        exportContent = result.Export?.Content;
        exportFileName = result.Export?.FileName;
        downloadHref = result.Export?.BinaryContent is { Length: > 0 } binary
            ? $"data:{result.Export.ContentType};base64,{Convert.ToBase64String(binary)}"
            : null;
        await LoadAsync();
    }
    private async Task ArchiveSelectedRunsAsync(){ var result = await Reports.ArchiveRunsAsync(new ArchiveSystemReportRunsRequest(selectedKey, archiveBefore.AddDays(1), requestedBy)); success = result.Success; message = result.Message; await LoadAsync(); }
    private async Task LoadArchivedRunsAsync(){ runs = await Reports.GetRunsAsync(selectedKey, true); }
    private async Task SelectAndGenerateAsync(string key){ selectedKey = key; await GenerateAsync(); }
    private async Task SelectAndExportAsync(string key){ selectedKey = key; await ExportAsync(); }
    private async Task SaveDefinitionAsync()
    {
        var result = await Reports.SaveDefinitionAsync(editingDefinitionId, new SaveSystemReportDefinitionRequest(definitionKey, definitionNameAr, definitionKind, definitionSourceDomain, definitionIsActive));
        success = result.Success;
        message = result.Message;
        if (success)
            ResetDefinitionForm();
        await LoadAsync();
    }

    private async Task ToggleDefinitionAsync(SystemReportDefinitionResponse definition)
    {
        var result = await Reports.SaveDefinitionAsync(definition.Id, new SaveSystemReportDefinitionRequest(definition.Key, definition.NameAr, SystemReportKind.Report, definition.SourceDomain, !definition.IsActive));
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void EditDefinition(SystemReportDefinitionResponse definition)
    {
        editingDefinitionId = definition.Id;
        definitionKey = definition.Key;
        definitionNameAr = definition.NameAr;
        definitionKind = Enum.TryParse<SystemReportKind>(definition.Kind, out var parsedKind) ? parsedKind : SystemReportKind.Report;
        definitionSourceDomain = definition.SourceDomain;
        definitionIsActive = definition.IsActive;
    }

    private void ResetDefinitionForm()
    {
        editingDefinitionId = null;
        definitionKey = string.Empty;
        definitionNameAr = string.Empty;
        definitionKind = SystemReportKind.Report;
        definitionSourceDomain = string.Empty;
        definitionIsActive = true;
    }
}
