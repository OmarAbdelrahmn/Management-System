@page "/beneficiary-services/entity-supports"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject BeneficiaryServicesUiService Services
@inject BeneficiaryUiService Beneficiaries

<h1 class="page-title">إدارة طلبات الجهات</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-building-user"></i><div><h2>@(editingSupportId.HasValue ? "تعديل طلب جهة" : "طلب جهة")</h2><p>طلبات دعم الجهات الداخلية والخارجية مع اعتمادها وتحويلها لأوامر صرف.</p></div></div>
    <div class="form-grid compact">
        <label>الجهة<select @bind="entityIdText"><option value="">بدون جهة</option>@foreach (var entity in entities){<option value="@entity.Id">@entity.NameAr</option>}</select></label>
        <label>اسم مقدم الطلب<input @bind="requesterName" /></label>
        <label>نوع الدعم<input @bind="supportType" /></label>
        <label>المبلغ<input type="number" step="0.01" @bind="amount" /></label>
        <label>تاريخ أمر الصرف<input type="date" @bind="paymentDueDate" /></label>
        <label>ملاحظة القرار<input @bind="decisionNotes" /></label>
        <label><input type="checkbox" @bind="isExternal" /> من الموقع</label>
    </div>
    <div class="actions-row">
        <button class="primary" @onclick="SaveAsync">@(editingSupportId.HasValue ? "تحديث الطلب" : "حفظ الطلب")</button>
        @if (editingSupportId.HasValue)
        {
            <button class="secondary" @onclick="ResetForm">إلغاء التعديل</button>
        }
    </div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-database"></i> طلبات الجهات</span></div>
    <table>
        <thead><tr><th>الجهة</th><th>مقدم الطلب</th><th>نوع الدعم</th><th>المبلغ</th><th>الحالة</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var item in supports)
            {
                <tr>
                    <td>@item.EntityName</td>
                    <td>@item.RequesterName</td>
                    <td>@item.SupportType</td>
                    <td>@item.Amount</td>
                    <td>@item.Status</td>
                    <td>
                        <button class="secondary" @onclick="@(() => EditSupport(item))">تعديل</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(item.Id, EntitySupportStatus.Approved))">اعتماد</button>
                        <button class="secondary" @onclick="@(() => CreatePaymentOrderAsync(item.Id))">أمر صرف</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(item.Id, EntitySupportStatus.Rejected))">رفض</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<BeneficiaryEntityResponse> entities = [];
    private List<EntitySupportResponse> supports = [];
    private int? editingSupportId;
    private string entityIdText = string.Empty;
    private string requesterName = string.Empty;
    private string supportType = string.Empty;
    private decimal amount;
    private DateTime? paymentDueDate = DateTime.UtcNow.AddHours(3).Date.AddDays(7);
    private string? decisionNotes;
    private bool isExternal;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        entities = await Beneficiaries.GetEntitiesAsync(status: BeneficiaryEntityStatus.Active);
        await LoadAsync();
    }

    private async Task LoadAsync() => supports = await Services.GetEntitySupportsAsync();

    private async Task SaveAsync()
    {
        var entityId = int.TryParse(entityIdText, out var value) ? value : (int?)null;
        var result = await Services.SaveEntitySupportAsync(editingSupportId, new SaveEntitySupportRequest(entityId, requesterName, supportType, amount, isExternal));
        success = result.Success;
        message = result.Message;
        if (result.Success)
            ResetForm();
        await LoadAsync();
    }

    private void EditSupport(EntitySupportResponse item)
    {
        editingSupportId = item.Id;
        entityIdText = item.BeneficiaryEntityId?.ToString() ?? string.Empty;
        requesterName = item.RequesterName;
        supportType = item.SupportType;
        amount = item.Amount;
        isExternal = item.IsExternal;
        decisionNotes = item.DecisionNotes;
        message = null;
    }

    private async Task DecideAsync(int id, EntitySupportStatus status)
    {
        var result = await Services.DecideEntitySupportAsync(id, status, decisionNotes);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private async Task CreatePaymentOrderAsync(int id)
    {
        var result = await Services.CreatePaymentOrderFromEntitySupportAsync(id, PaymentOrderType.Finance, paymentDueDate, decisionNotes ?? "أمر صرف من طلب جهة");
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void ResetForm()
    {
        editingSupportId = null;
        entityIdText = string.Empty;
        requesterName = string.Empty;
        supportType = string.Empty;
        amount = 0;
        paymentDueDate = DateTime.UtcNow.AddHours(3).Date.AddDays(7);
        decisionNotes = null;
        isExternal = false;
    }
}
