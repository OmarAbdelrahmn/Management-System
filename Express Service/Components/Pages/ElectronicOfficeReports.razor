@page "/electronic-office/reports"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject ElectronicOfficeUiService Office

<h1 class="page-title">التقارير و السجلات</h1>
@if (!string.IsNullOrWhiteSpace(message)){<section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>}
<section class="panel"><div class="panel-heading"><i class="fa-solid fa-chart-column"></i><div><h2>سجل مكتبي</h2><p>بطاقة التعريف، الملف والسجل الوظيفي، الشروحات، التنبيهات، أرصدة الإجازات، سجلات الحضور، والمهام والمؤشرات.</p></div></div><div class="form-grid compact"><label>النوع<select @bind="logType"><option value="@OfficeLogType.NgoInformation">بطاقة التعريف</option><option value="@OfficeLogType.EmployeeProfile">الملف الوظيفي</option><option value="@OfficeLogType.EmployeeRecord">السجل الوظيفي</option><option value="@OfficeLogType.Tutorial">شروحات النظام</option><option value="@OfficeLogType.LocalNotification">تنبيه داخلي</option><option value="@OfficeLogType.DirectedNotification">إشعار موجه</option><option value="@OfficeLogType.ReminderNotification">تنبيه مذكرة</option><option value="@OfficeLogType.VacationCredit">رصيد إجازة</option><option value="@OfficeLogType.AttendanceReport">حضور وانصراف</option><option value="@OfficeLogType.AttendanceRejected">حضور مرفوض</option><option value="@OfficeLogType.MyTasks">مهامي</option><option value="@OfficeLogType.ProjectTasks">مهام المشاريع</option><option value="@OfficeLogType.StrategyTasks">مهام الخطة</option><option value="@OfficeLogType.StrategyIndicators">المؤشرات</option><option value="@OfficeLogType.MailPreference">تفضيلات البريد</option></select></label><label>العنوان<input @bind="title" /></label><label>المرجع<input @bind="reference" /></label><label>التاريخ<input type="date" @bind="recordDate" /></label><label class="span-2">ملاحظات<input @bind="notes" /></label></div><div class="actions-row"><button class="primary" @onclick="SaveAsync">حفظ السجل</button><button class="secondary" @onclick="LoadAttendanceAsync">الحضور</button><button class="secondary" @onclick="LoadAsync">كل السجلات</button></div></section>
<section class="table-section"><div class="table-title"><span><i class="fa-solid fa-database"></i> السجلات</span></div><table><thead><tr><th>النوع</th><th>العنوان</th><th>المرجع</th><th>التاريخ</th><th>ملاحظات</th></tr></thead><tbody>@foreach (var item in logs){<tr><td>@item.LogType</td><td>@item.Title</td><td>@item.Reference</td><td>@item.RecordDate.ToString("yyyy-MM-dd")</td><td>@item.Notes</td></tr>}</tbody></table></section>
@code {
    private List<OfficeLogRecordResponse> logs = [];
    private OfficeLogType logType = OfficeLogType.EmployeeRecord;
    private string title = string.Empty;
    private string? reference;
    private string? notes;
    private DateTime recordDate = DateTime.UtcNow.AddHours(3).Date;
    private bool success;
    private string? message;
    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync() => logs = await Office.GetLogRecordsAsync();
    private async Task LoadAttendanceAsync() => logs = await Office.GetLogRecordsAsync(OfficeLogType.AttendanceReport);
    private async Task SaveAsync(){ var result = await Office.SaveLogRecordAsync(null, new SaveOfficeLogRecordRequest(logType, title, reference, notes, recordDate)); success = result.Success; message = result.Message; await LoadAsync(); }
}
