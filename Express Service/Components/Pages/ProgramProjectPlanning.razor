@page "/programs-projects/planning"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject ProgramsProjectsUiService ProgramsProjects

<h1 class="page-title">مرحلة الإعداد والتخطيط</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-list-check"></i><div><h2>مهمة مشروع</h2><p>إدارة مهام المشروع وأنشطته وعقوده.</p></div></div>
    <div class="form-grid compact">
        <label>المشروع<select @bind="projectId">@foreach (var project in projects){<option value="@project.Id">@project.Name</option>}</select></label>
        <label>عنوان المهمة<input @bind="taskTitle" /></label>
        <label>المسؤول<input @bind="ownerName" /></label>
        <label>تاريخ الاستحقاق<input type="date" @bind="dueDate" /></label>
        <label>الحالة<select @bind="taskStatus"><option value="@ProgramProjectTaskStatus.New">جديدة</option><option value="@ProgramProjectTaskStatus.Running">جارية</option><option value="@ProgramProjectTaskStatus.Blocked">متعثرة</option><option value="@ProgramProjectTaskStatus.Completed">منجزة</option></select></label>
        <label>نسبة الإنجاز<input type="number" step="1" @bind="progressPercent" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveTaskAsync">حفظ المهمة</button></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-calendar-check"></i><div><h2>نشاط مشروع</h2><p>تسجيل الأنشطة والمراحل الزمنية.</p></div></div>
    <div class="form-grid compact">
        <label>العنوان<input @bind="milestoneTitle" /></label>
        <label>من<input type="date" @bind="milestoneStart" /></label>
        <label>إلى<input type="date" @bind="milestoneEnd" /></label>
        <label>نسبة الإنجاز<input type="number" step="1" @bind="milestoneProgress" /></label>
        <label class="span-2">ملاحظات<input @bind="milestoneNotes" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveMilestoneAsync">حفظ النشاط</button></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-file-contract"></i><div><h2>عقد ودفعات</h2><p>ربط العقد بالمشروع والمورد عند توفره.</p></div></div>
    <div class="form-grid compact">
        <label>المورد<select @bind="supplierIdText"><option value="">بدون مورد</option>@foreach (var supplier in suppliers){<option value="@supplier.Id">@supplier.Name</option>}</select></label>
        <label>رقم العقد<input @bind="contractNumber" placeholder="يولد تلقائياً عند تركه فارغاً" /></label>
        <label>العنوان<input @bind="contractTitle" /></label>
        <label>المبلغ<input type="number" step="0.01" @bind="contractAmount" /></label>
        <label>تاريخ التوقيع<input type="date" @bind="signedAt" /></label>
        <label>تاريخ النهاية<input type="date" @bind="contractEndsAt" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveContractAsync">حفظ العقد</button><button class="secondary" @onclick="LoadAsync">تحديث</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-timeline"></i> التخطيط الحالي</span></div>
    <table>
        <thead><tr><th>النوع</th><th>المشروع</th><th>العنوان</th><th>تفاصيل</th><th>الحالة/الإنجاز</th></tr></thead>
        <tbody>
            @foreach (var task in tasks)
            {
                <tr><td>مهمة</td><td>@task.ProjectName</td><td>@task.Title</td><td>@task.OwnerName / @task.DueDate?.ToString("yyyy-MM-dd")</td><td>@task.Status - @task.ProgressPercent%</td></tr>
            }
            @foreach (var milestone in milestones)
            {
                <tr><td>نشاط</td><td>@milestone.ProjectName</td><td>@milestone.Title</td><td>@milestone.StartsAt.ToString("yyyy-MM-dd") - @milestone.EndsAt.ToString("yyyy-MM-dd")</td><td>@milestone.ProgressPercent%</td></tr>
            }
            @foreach (var contract in contracts)
            {
                <tr><td>عقد</td><td>@contract.ProjectName</td><td>@contract.Title</td><td>@contract.ContractNumber / @contract.SupplierName</td><td>@contract.Amount</td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<ProgramProjectResponse> projects = [];
    private List<ProgramSupplierResponse> suppliers = [];
    private List<ProgramProjectTaskResponse> tasks = [];
    private List<ProgramProjectMilestoneResponse> milestones = [];
    private List<ProgramProjectContractResponse> contracts = [];
    private int projectId;
    private string taskTitle = string.Empty;
    private string? ownerName;
    private DateTime? dueDate = DateTime.UtcNow.AddHours(3).Date.AddDays(7);
    private ProgramProjectTaskStatus taskStatus = ProgramProjectTaskStatus.New;
    private decimal progressPercent;
    private string milestoneTitle = string.Empty;
    private DateTime milestoneStart = DateTime.UtcNow.AddHours(3).Date;
    private DateTime milestoneEnd = DateTime.UtcNow.AddHours(3).Date.AddDays(7);
    private decimal milestoneProgress;
    private string? milestoneNotes;
    private string supplierIdText = string.Empty;
    private string? contractNumber;
    private string contractTitle = string.Empty;
    private decimal contractAmount;
    private DateTime signedAt = DateTime.UtcNow.AddHours(3).Date;
    private DateTime? contractEndsAt = DateTime.UtcNow.AddHours(3).Date.AddMonths(1);
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        projects = await ProgramsProjects.SearchProjectsAsync();
        suppliers = await ProgramsProjects.GetSuppliersAsync();
        projectId = projects.FirstOrDefault()?.Id ?? 0;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        tasks = await ProgramsProjects.GetTasksAsync();
        milestones = await ProgramsProjects.GetMilestonesAsync();
        contracts = await ProgramsProjects.GetContractsAsync();
    }

    private async Task SaveTaskAsync()
    {
        var result = await ProgramsProjects.SaveTaskAsync(null, new SaveProgramProjectTaskRequest(projectId, taskTitle, ownerName, dueDate, taskStatus, progressPercent, null));
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private async Task SaveMilestoneAsync()
    {
        var result = await ProgramsProjects.SaveMilestoneAsync(null, new SaveProgramProjectMilestoneRequest(projectId, milestoneTitle, milestoneStart, milestoneEnd, milestoneProgress, milestoneNotes));
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private async Task SaveContractAsync()
    {
        var supplierId = int.TryParse(supplierIdText, out var value) ? value : (int?)null;
        var result = await ProgramsProjects.SaveContractAsync(null, new SaveProgramProjectContractRequest(projectId, supplierId, contractNumber, contractTitle, contractAmount, signedAt, contractEndsAt, null));
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }
}
