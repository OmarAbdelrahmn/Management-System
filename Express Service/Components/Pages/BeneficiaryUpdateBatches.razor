@page "/beneficiaries/update-batches"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject BeneficiaryUiService Beneficiaries

<h1 class="page-title">مهام وتقارير تحديث بيانات المستفيدين</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-clipboard-list"></i><div><h2>@(editingBatchId.HasValue ? "تعديل مهمة أو تقرير تحديث" : "إنشاء مهمة أو تقرير تحديث")</h2><p>يغطي التحديث الجماعي، التحديث الذاتي، تحديث طلب الإعانة، والتقارير غير المحدثة أو الخاطئة.</p></div></div>
    <div class="form-grid">
        <label>النوع<select @bind="batchKind"><option value="@BeneficiaryUpdateBatchKind.BulkUpdate">تحديث جماعي</option><option value="@BeneficiaryUpdateBatchKind.SelfService">تحديث ذاتي</option><option value="@BeneficiaryUpdateBatchKind.AidRequest">تحديث لطلب إعانة</option><option value="@BeneficiaryUpdateBatchKind.ManualStatus">تحديث حالة يدوي</option><option value="@BeneficiaryUpdateBatchKind.ReportNoUpdate">ملفات غير محدثة</option><option value="@BeneficiaryUpdateBatchKind.ReportWrongUpdate">ملفات محدثة خاطئة</option><option value="@BeneficiaryUpdateBatchKind.ReportSelfUpdate">ملفات تحديث ذاتي</option><option value="@BeneficiaryUpdateBatchKind.ReportFieldUpdate">ملفات تحديث ميداني</option></select></label>
        <label>العنوان<input @bind="title" /></label>
        <label>المسؤول<input @bind="assignedTo" /></label>
        <label>عدد الملفات<input type="number" @bind="totalProfiles" /></label>
        <label>تاريخ الاستحقاق<input type="date" @bind="dueDate" /></label>
        <label class="span-2">ملاحظات<textarea @bind="notes"></textarea></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveAsync">@(editingBatchId.HasValue ? "حفظ التعديل" : "إنشاء المهمة")</button><button class="secondary" @onclick="ResetForm">جديد</button><button class="secondary" @onclick="LoadAsync">تحديث القائمة</button></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-chart-line"></i><div><h2>تحديث التقدم</h2><p>استخدم القيم التالية لتحديث المهمة المختارة من الجدول.</p></div></div>
    <div class="form-grid compact">
        <label>الحالة<select @bind="progressStatus"><option value="@BeneficiaryOperationStatus.Pending">بانتظار التنفيذ</option><option value="@BeneficiaryOperationStatus.Approved">قيد التنفيذ</option><option value="@BeneficiaryOperationStatus.Completed">مكتملة</option><option value="@BeneficiaryOperationStatus.Cancelled">ملغية</option></select></label>
        <label>المنجز<input type="number" @bind="completedProfiles" /></label>
        <label class="span-2">ملاحظات التقدم<input @bind="progressNotes" /></label>
    </div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-database"></i> مهام وتقارير التحديث</span></div>
    <table>
        <thead><tr><th>الرقم</th><th>العنوان</th><th>النوع</th><th>الحالة</th><th>المسؤول</th><th>التقدم</th><th>استحقاق</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var batch in batches)
            {
                <tr>
                    <td>@batch.BatchNumber</td>
                    <td>@batch.Title</td>
                    <td>@batch.Kind</td>
                    <td><span class="status">@batch.Status</span></td>
                    <td>@batch.AssignedTo</td>
                    <td>@batch.CompletedProfiles / @batch.TotalProfiles</td>
                    <td>@batch.DueDate?.ToString("yyyy-MM-dd")</td>
                    <td><button class="secondary" @onclick="() => Edit(batch)">تعديل</button> <button class="secondary" @onclick="() => UpdateProgressAsync(batch.Id)">تحديث التقدم</button></td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<BeneficiaryUpdateBatchResponse> batches = [];
    private BeneficiaryUpdateBatchKind batchKind = BeneficiaryUpdateBatchKind.BulkUpdate;
    private string title = string.Empty;
    private string? assignedTo;
    private int totalProfiles;
    private DateTime? dueDate;
    private string? notes;
    private int? editingBatchId;
    private BeneficiaryOperationStatus progressStatus = BeneficiaryOperationStatus.Approved;
    private int completedProfiles;
    private string? progressNotes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() => batches = await Beneficiaries.GetUpdateBatchesAsync();

    private async Task SaveAsync()
    {
        var result = editingBatchId.HasValue
            ? await Beneficiaries.UpdateUpdateBatchAsync(editingBatchId.Value, new UpdateBeneficiaryUpdateBatchRequest(batchKind, title, assignedTo, totalProfiles, dueDate, notes))
            : await Beneficiaries.CreateUpdateBatchAsync(new CreateBeneficiaryUpdateBatchRequest(batchKind, title, assignedTo, totalProfiles, dueDate, notes));
        success = result.Success;
        message = result.Message;
        if (success)
        {
            ResetForm();
            await LoadAsync();
        }
    }

    private async Task UpdateProgressAsync(int id)
    {
        var result = await Beneficiaries.UpdateBatchProgressAsync(id, progressStatus, completedProfiles, progressNotes);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void Edit(BeneficiaryUpdateBatchResponse batch)
    {
        editingBatchId = batch.Id;
        batchKind = Enum.Parse<BeneficiaryUpdateBatchKind>(batch.Kind);
        title = batch.Title;
        assignedTo = batch.AssignedTo;
        totalProfiles = batch.TotalProfiles;
        dueDate = batch.DueDate;
        notes = batch.Notes;
    }

    private void ResetForm()
    {
        editingBatchId = null;
        batchKind = BeneficiaryUpdateBatchKind.BulkUpdate;
        title = string.Empty;
        assignedTo = null;
        totalProfiles = 0;
        dueDate = null;
        notes = null;
    }
}
