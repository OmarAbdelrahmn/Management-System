@page "/beneficiary-services/payment-orders"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject BeneficiaryServicesUiService Services
@inject BeneficiaryUiService Beneficiaries

<h1 class="page-title">إدارة أوامر الصرف</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-money-check"></i><div><h2>@(editingOrderId.HasValue ? "تعديل أمر صرف" : "أمر صرف")</h2><p>أوامر الصرف المالية والعينية وحالات الرفض والإغلاق.</p></div></div>
    <div class="form-grid compact">
        <label>المستفيد<select @bind="beneficiaryIdText"><option value="">بدون مستفيد</option>@foreach (var beneficiary in beneficiaries){<option value="@beneficiary.Id">@beneficiary.FullName</option>}</select></label>
        <label>طلب الإعانة<select @bind="aidRequestIdText"><option value="">بدون طلب</option>@foreach (var request in aidRequests){<option value="@request.Id">@request.RequestNumber</option>}</select></label>
        <label>رقم الأمر<input @bind="orderNumber" placeholder="يولد تلقائيا عند تركه فارغا" /></label>
        <label>النوع<select @bind="orderType"><option value="@PaymentOrderType.Finance">مالي</option><option value="@PaymentOrderType.Storage">عيني</option></select></label>
        <label>المبلغ<input type="number" step="0.01" @bind="amount" /></label>
        <label>الاستحقاق<input type="date" @bind="dueDate" /></label>
        <label>الوصف<input @bind="itemDescription" /></label>
        <label>ملاحظة القرار<input @bind="decisionNotes" /></label>
    </div>
    <div class="actions-row">
        <button class="primary" @onclick="SaveAsync">@(editingOrderId.HasValue ? "تحديث أمر الصرف" : "حفظ أمر الصرف")</button>
        @if (editingOrderId.HasValue)
        {
            <button class="secondary" @onclick="ResetForm">إلغاء التعديل</button>
        }
    </div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-database"></i> أوامر الصرف</span></div>
    <table>
        <thead><tr><th>الرقم</th><th>المستفيد</th><th>النوع</th><th>المبلغ</th><th>الحالة</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var order in orders)
            {
                <tr>
                    <td>@order.OrderNumber</td>
                    <td>@order.BeneficiaryName</td>
                    <td>@order.OrderType</td>
                    <td>@order.Amount</td>
                    <td><span class="status">@order.Status</span></td>
                    <td>
                        <button class="secondary" @onclick="@(() => EditOrder(order))">تعديل</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(order.Id, PaymentOrderStatus.Approved))">اعتماد</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(order.Id, PaymentOrderStatus.RejectedWithNote))">ملاحظة</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(order.Id, PaymentOrderStatus.Rejected))">رفض</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(order.Id, PaymentOrderStatus.Closed))">إغلاق</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(order.Id, PaymentOrderStatus.Removed))">حذف</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<BeneficiaryResponse> beneficiaries = [];
    private List<AidRequestResponse> aidRequests = [];
    private List<PaymentOrderResponse> orders = [];
    private int? editingOrderId;
    private string beneficiaryIdText = string.Empty;
    private string aidRequestIdText = string.Empty;
    private string? orderNumber;
    private PaymentOrderType orderType = PaymentOrderType.Finance;
    private decimal amount;
    private DateTime? dueDate = DateTime.UtcNow.AddHours(3).Date;
    private string itemDescription = string.Empty;
    private string? decisionNotes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        beneficiaries = await Beneficiaries.SearchAsync(status: BeneficiaryStatus.Active);
        aidRequests = await Services.GetAidRequestsAsync();
        await LoadAsync();
    }

    private async Task LoadAsync() => orders = await Services.GetPaymentOrdersAsync();

    private async Task SaveAsync()
    {
        var beneficiaryId = int.TryParse(beneficiaryIdText, out var beneficiaryValue) ? beneficiaryValue : (int?)null;
        var aidRequestId = int.TryParse(aidRequestIdText, out var aidValue) ? aidValue : (int?)null;
        var result = await Services.SavePaymentOrderAsync(editingOrderId, new SavePaymentOrderRequest(aidRequestId, beneficiaryId, orderNumber, orderType, amount, itemDescription, dueDate));
        success = result.Success;
        message = result.Message;
        if (result.Success)
            ResetForm();
        await LoadAsync();
    }

    private void EditOrder(PaymentOrderResponse order)
    {
        editingOrderId = order.Id;
        beneficiaryIdText = order.BeneficiaryProfileId?.ToString() ?? string.Empty;
        aidRequestIdText = order.BeneficiaryAidRequestId?.ToString() ?? string.Empty;
        orderNumber = order.OrderNumber;
        orderType = Enum.TryParse<PaymentOrderType>(order.OrderType, out var parsedType) ? parsedType : PaymentOrderType.Finance;
        amount = order.Amount;
        itemDescription = order.ItemDescription;
        dueDate = order.DueDate;
        decisionNotes = order.DecisionNotes;
        message = null;
    }

    private async Task DecideAsync(int id, PaymentOrderStatus status)
    {
        var result = await Services.DecidePaymentOrderAsync(id, status, decisionNotes);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void ResetForm()
    {
        editingOrderId = null;
        beneficiaryIdText = string.Empty;
        aidRequestIdText = string.Empty;
        orderNumber = null;
        orderType = PaymentOrderType.Finance;
        amount = 0;
        dueDate = DateTime.UtcNow.AddHours(3).Date;
        itemDescription = string.Empty;
        decisionNotes = null;
    }
}
