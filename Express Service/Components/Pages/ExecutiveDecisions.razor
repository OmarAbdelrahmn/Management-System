@page "/executive-supervision/decisions"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject ExecutiveSupervisionUiService Executive

<h1 class="page-title">إدارة القرارات الإدارية</h1>
@if (!string.IsNullOrWhiteSpace(message)){<section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>}
<section class="panel"><div class="panel-heading"><i class="fa-solid fa-scale-balanced"></i><div><h2>قرار إداري</h2><p>القرارات الإدارية، قرارات الاجتماعات، مهام القرارات، وتصدير نماذج القرارات.</p></div></div><div class="form-grid compact"><label>رقم القرار<input @bind="decisionNumber" /></label><label>النوع<select @bind="decisionType"><option value="@AdministrativeDecisionType.Administrative">إداري</option><option value="@AdministrativeDecisionType.Meeting">اجتماع</option><option value="@AdministrativeDecisionType.DecisionTask">مهمة قرار</option><option value="@AdministrativeDecisionType.ExportTemplate">نموذج تصدير</option></select></label><label>العنوان<input @bind="title" /></label><label>رمز الاجتماع<input @bind="relatedMeetingCode" /></label><label>المسند إليه<input @bind="assignedTo" /></label><label>الحالة<select @bind="status"><option value="@ExecutiveWorkflowStatus.Pending">معلق</option><option value="@ExecutiveWorkflowStatus.Approved">معتمد</option><option value="@ExecutiveWorkflowStatus.Completed">مكتمل</option></select></label><label>تاريخ القرار<input type="date" @bind="decisionDate" /></label><label>نموذج التصدير<input @bind="exportTemplateName" /></label><label class="span-2">ملاحظات<input @bind="notes" /></label></div><div class="actions-row"><button class="primary" @onclick="SaveAsync">حفظ القرار</button><button class="secondary" @onclick="LoadMeetingsAsync">قرارات الاجتماعات</button><button class="secondary" @onclick="LoadAsync">كل القرارات</button></div></section>
<section class="table-section"><div class="table-title"><span><i class="fa-solid fa-database"></i> القرارات</span></div><table><thead><tr><th>القرار</th><th>النوع</th><th>العنوان</th><th>المسند</th><th>الحالة</th></tr></thead><tbody>@foreach (var item in decisions){<tr><td>@item.DecisionNumber<br />@item.DecisionDate.ToString("yyyy-MM-dd")</td><td>@item.DecisionType</td><td>@item.Title<br />@item.RelatedMeetingCode</td><td>@item.AssignedTo<br />@item.ExportTemplateName</td><td>@item.Status<br />@item.Notes</td></tr>}</tbody></table></section>
@code {
    private List<AdministrativeDecisionRecordResponse> decisions = [];
    private string decisionNumber = $"DEC-{DateTime.UtcNow:yyyyMMddHHmm}";
    private AdministrativeDecisionType decisionType = AdministrativeDecisionType.Administrative;
    private string title = string.Empty;
    private string? relatedMeetingCode;
    private string? assignedTo;
    private ExecutiveWorkflowStatus status = ExecutiveWorkflowStatus.Pending;
    private DateTime decisionDate = DateTime.UtcNow.AddHours(3).Date;
    private string? exportTemplateName;
    private string? notes;
    private bool success;
    private string? message;
    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync() => decisions = await Executive.GetAdministrativeDecisionsAsync();
    private async Task LoadMeetingsAsync() => decisions = await Executive.GetAdministrativeDecisionsAsync(AdministrativeDecisionType.Meeting);
    private async Task SaveAsync(){ var result = await Executive.SaveAdministrativeDecisionAsync(null, new SaveAdministrativeDecisionRecordRequest(decisionNumber, decisionType, title, relatedMeetingCode, assignedTo, status, decisionDate, exportTemplateName, notes)); success = result.Success; message = result.Message; if (success) decisionNumber = $"DEC-{DateTime.UtcNow:yyyyMMddHHmmss}"; await LoadAsync(); }
}
