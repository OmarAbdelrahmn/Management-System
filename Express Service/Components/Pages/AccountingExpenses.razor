@page "/accounting/expenses"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject AccountingUiService Accounting

<h1 class="page-title">المصروفات والرواتب</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="form-grid compact">
        <label>نوع الصرف<select @bind="expenseKind"><option value="@ExpenseVoucherKind.Generic">عام</option><option value="@ExpenseVoucherKind.Authorization">تعميد</option><option value="@ExpenseVoucherKind.PaymentOrder">أمر صرف</option><option value="@ExpenseVoucherKind.Sponsorship">كفالة</option><option value="@ExpenseVoucherKind.CustodySettlement">تسوية عهدة</option></select></label>
        <label>المستفيد من الصرف<input @bind="payeeName" /></label>
        <label>المبلغ<input type="number" step="0.01" @bind="amount" /></label>
        <label>شهر الرواتب<input type="date" @bind="payrollMonth" /></label>
        <label>إجمالي الرواتب<input type="number" step="0.01" @bind="salaryAmount" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveExpenseAsync">حفظ سند صرف</button><button class="secondary" @onclick="SaveSalaryAsync">حفظ صرف رواتب</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-money-bill-transfer"></i> المصروفات</span></div>
    <table>
        <thead><tr><th>النوع</th><th>الرقم/الشهر</th><th>المستفيد</th><th>المبلغ</th><th>الحالة</th></tr></thead>
        <tbody>
            @foreach (var expense in expenses){<tr><td>@expense.Kind</td><td>@expense.ExpenseNumber</td><td>@expense.PayeeName</td><td>@expense.Amount</td><td>@expense.Status</td></tr>}
            @foreach (var salary in salaries){<tr><td>رواتب</td><td>@salary.PayrollMonth.ToString("yyyy-MM")</td><td>@salary.ExportFormat</td><td>@salary.TotalAmount</td><td>@salary.Status</td></tr>}
        </tbody>
    </table>
</section>

@code {
    private List<ExpenseVoucherResponse> expenses = [];
    private List<SalaryDisbursementResponse> salaries = [];
    private ExpenseVoucherKind expenseKind = ExpenseVoucherKind.Generic;
    private string payeeName = string.Empty;
    private decimal amount;
    private DateTime payrollMonth = DateTime.UtcNow.AddHours(3).Date;
    private decimal salaryAmount;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync(){ expenses = await Accounting.GetExpensesAsync(); salaries = await Accounting.GetSalaryDisbursementsAsync(); }
    private async Task SaveExpenseAsync(){ var r = await Accounting.SaveExpenseAsync(null, new SaveExpenseVoucherRequest(null, expenseKind, DateTime.UtcNow.AddHours(3), amount, payeeName, AccountingRecordStatus.Posted, null)); success = r.Success; message = r.Message; await LoadAsync(); }
    private async Task SaveSalaryAsync(){ var r = await Accounting.SaveSalaryDisbursementAsync(null, new SaveSalaryDisbursementRequest(payrollMonth, salaryAmount, "Rajhi/Export", AccountingRecordStatus.Posted, null)); success = r.Success; message = r.Message; await LoadAsync(); }
}
