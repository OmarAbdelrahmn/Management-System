@page "/programs-projects/monitoring"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject ProgramsProjectsUiService ProgramsProjects

<h1 class="page-title">مخطط المشروع ولوحة كانبان والمؤشرات</h1>

<section class="circle-tiles">
    <article class="circle-tile-content"><span class="circle-icon bg-blue"><i class="fa-solid fa-diagram-project"></i></span><span>المشاريع</span><strong class="tile-number">@(dashboard?.ProjectsCount ?? 0)</strong><span class="tile-footer">إجمالي</span></article>
    <article class="circle-tile-content"><span class="circle-icon bg-teal"><i class="fa-solid fa-play"></i></span><span>النشطة</span><strong class="tile-number">@(dashboard?.ActiveProjectsCount ?? 0)</strong><span class="tile-footer">قيد التنفيذ</span></article>
    <article class="circle-tile-content"><span class="circle-icon bg-orange"><i class="fa-solid fa-check"></i></span><span>المكتملة</span><strong class="tile-number">@(dashboard?.CompletedProjectsCount ?? 0)</strong><span class="tile-footer">منتهية</span></article>
    <article class="circle-tile-content"><span class="circle-icon bg-purple"><i class="fa-solid fa-scale-balanced"></i></span><span>الرصيد</span><strong class="tile-number">@((dashboard?.TotalIncome ?? 0) - (dashboard?.TotalExpenses ?? 0))</strong><span class="tile-footer">مالي</span></article>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-chart-gantt"></i><div><h2>مخطط زمني</h2><p>عرض مبسط لمراحل المشروع ونسب الإنجاز.</p></div></div>
    <div class="table-section compact-table">
        <table>
            <thead><tr><th>المشروع</th><th>النشاط</th><th>الفترة</th><th>الإنجاز</th></tr></thead>
            <tbody>
                @foreach (var milestone in milestones)
                {
                    <tr>
                        <td>@milestone.ProjectName</td>
                        <td>@milestone.Title</td>
                        <td>@milestone.StartsAt.ToString("yyyy-MM-dd") - @milestone.EndsAt.ToString("yyyy-MM-dd")</td>
                        <td><progress max="100" value="@milestone.ProgressPercent"></progress> @milestone.ProgressPercent%</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-table-columns"></i> لوحة كانبان</span></div>
    <table>
        <thead><tr><th>جديدة</th><th>جارية</th><th>متعثرة</th><th>منجزة</th><th>مكتملة</th></tr></thead>
        <tbody>
            <tr>
                <td>@foreach (var task in TasksByStatus("New")){<div>@task.Title<br /><small>@task.ProjectName</small></div>}</td>
                <td>@foreach (var task in TasksByStatus("Running")){<div>@task.Title<br /><small>@task.ProjectName</small></div>}</td>
                <td>@foreach (var task in TasksByStatus("Blocked")){<div>@task.Title<br /><small>@task.ProjectName</small></div>}</td>
                <td>@foreach (var task in TasksByStatus("Completed")){<div>@task.Title<br /><small>@task.ProjectName</small></div>}</td>
                <td>@foreach (var task in TasksByStatus("Finished")){<div>@task.Title<br /><small>@task.ProjectName</small></div>}</td>
            </tr>
        </tbody>
    </table>
</section>

@code {
    private ProgramsProjectsDashboardResponse? dashboard;
    private List<ProgramProjectTaskResponse> tasks = [];
    private List<ProgramProjectMilestoneResponse> milestones = [];

    protected override async Task OnInitializedAsync()
    {
        dashboard = await ProgramsProjects.GetDashboardAsync();
        tasks = await ProgramsProjects.GetTasksAsync();
        milestones = await ProgramsProjects.GetMilestonesAsync();
    }

    private IEnumerable<ProgramProjectTaskResponse> TasksByStatus(string status) =>
        tasks.Where(x => x.Status == status);
}
