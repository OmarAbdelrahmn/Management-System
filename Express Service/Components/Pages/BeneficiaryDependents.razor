@page "/beneficiaries/dependents"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject BeneficiaryUiService Beneficiaries

<h1 class="page-title">قاعدة بيانات التابعين</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-people-roof"></i><div><h2>إضافة تابع</h2><p>ربط التابع بملف مستفيد وتسجيل العلاقة والفئة.</p></div></div>
    <div class="form-grid">
        <label>المستفيد<select @bind="beneficiaryProfileId">@foreach (var profile in profiles){<option value="@profile.Id">@profile.BeneficiaryNumber - @profile.FullName</option>}</select></label>
        <label>اسم التابع<input @bind="fullName" /></label>
        <label>رقم الهوية<input @bind="nationalId" /></label>
        <label>صلة القرابة<input @bind="relationship" /></label>
        <label>تاريخ الميلاد<input type="date" @bind="birthDate" /></label>
        <label>الفئة<input @bind="category" /></label>
        <label>الدرجة<input @bind="grade" /></label>
        <label class="span-2">ملاحظات<textarea @bind="notes"></textarea></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveAsync">إضافة تابع</button><button class="secondary" @onclick="LoadDependentsAsync">تحديث القائمة</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-users-line"></i> التابعون</span></div>
    <table>
        <thead><tr><th>المستفيد</th><th>التابع</th><th>الهوية</th><th>العلاقة</th><th>الفئة</th><th>نشط</th></tr></thead>
        <tbody>
            @foreach (var dependent in dependents)
            {
                <tr>
                    <td>@dependent.BeneficiaryName</td>
                    <td>@dependent.FullName</td>
                    <td>@dependent.NationalId</td>
                    <td>@dependent.Relationship</td>
                    <td>@dependent.Category @dependent.Grade</td>
                    <td>@(dependent.IsActive ? "نعم" : "لا")</td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<BeneficiaryResponse> profiles = [];
    private List<BeneficiaryDependentResponse> dependents = [];
    private int beneficiaryProfileId;
    private string fullName = string.Empty;
    private string? nationalId;
    private string relationship = string.Empty;
    private DateTime? birthDate;
    private string? category;
    private string? grade;
    private string? notes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        profiles = await Beneficiaries.SearchAsync(status: BeneficiaryStatus.Active);
        beneficiaryProfileId = profiles.FirstOrDefault()?.Id ?? 0;
        await LoadDependentsAsync();
    }

    private async Task LoadDependentsAsync() => dependents = await Beneficiaries.GetDependentsAsync(beneficiaryProfileId == 0 ? null : beneficiaryProfileId);

    private async Task SaveAsync()
    {
        var result = await Beneficiaries.AddDependentAsync(new AddBeneficiaryDependentRequest(beneficiaryProfileId, fullName, nationalId, relationship, birthDate, category, grade, notes));
        success = result.Success;
        message = result.Message;
        if (success)
        {
            fullName = string.Empty;
            nationalId = null;
            relationship = string.Empty;
            birthDate = null;
            category = null;
            grade = null;
            notes = null;
            await LoadDependentsAsync();
        }
    }
}
