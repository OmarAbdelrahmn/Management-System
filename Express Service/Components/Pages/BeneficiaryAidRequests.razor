@page "/beneficiary-services/aid-requests"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject BeneficiaryServicesUiService Services
@inject BeneficiaryUiService Beneficiaries

<h1 class="page-title">إدارة طلبات الإعانة</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-hand-holding-heart"></i><div><h2>@(editingRequestId.HasValue ? "تعديل طلب إعانة" : "طلب إعانة")</h2><p>إضافة وتعديل الطلبات الداخلية أو القادمة من الموقع ومتابعة اعتمادها.</p></div></div>
    <div class="form-grid">
        <label>المستفيد<select @bind="beneficiaryIdText"><option value="">بدون مستفيد</option>@foreach (var beneficiary in beneficiaries){<option value="@beneficiary.Id">@beneficiary.FullName</option>}</select></label>
        <label>الجهة<select @bind="entityIdText"><option value="">بدون جهة</option>@foreach (var entity in entities){<option value="@entity.Id">@entity.NameAr</option>}</select></label>
        <label>رقم الطلب<input @bind="requestNumber" placeholder="يولد تلقائيا عند تركه فارغا" /></label>
        <label>نوع الإعانة<input @bind="aidType" /></label>
        <label>المبلغ<input type="number" step="0.01" @bind="amount" /></label>
        <label><input type="checkbox" @bind="isExternal" /> طلب من الموقع</label>
        <label class="span-2">الوصف<textarea @bind="description"></textarea></label>
    </div>
    <div class="actions-row">
        <button class="primary" @onclick="SaveAsync">@(editingRequestId.HasValue ? "تحديث الطلب" : "حفظ الطلب")</button>
        @if (editingRequestId.HasValue)
        {
            <button class="secondary" @onclick="ResetForm">إلغاء التعديل</button>
        }
    </div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="form-grid compact">
        <label>الحالة<select @bind="statusText"><option value="">الكل</option>@foreach (var value in Enum.GetValues<AidRequestStatus>()){<option value="@value">@value</option>}</select></label>
        <label>نوع أمر الصرف<select @bind="paymentOrderType"><option value="@PaymentOrderType.Finance">مالي</option><option value="@PaymentOrderType.Storage">مستودع</option></select></label>
        <label>تاريخ الاستحقاق<input type="date" @bind="paymentDueDate" /></label>
        <label>رأي الباحث<input @bind="socialNotes" /></label>
        <label>ملاحظة القرار<input @bind="decisionNotes" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="LoadAsync">تحديث</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-database"></i> طلبات الإعانة</span></div>
    <table>
        <thead><tr><th>الرقم</th><th>المستفيد/الجهة</th><th>النوع</th><th>المبلغ</th><th>الحالة</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var item in requests)
            {
                <tr>
                    <td>@item.RequestNumber</td>
                    <td>@item.BeneficiaryName<br />@item.EntityName</td>
                    <td>@item.AidType</td>
                    <td>@item.Amount</td>
                    <td><span class="status">@item.Status</span></td>
                    <td>
                        <button class="secondary" @onclick="@(() => EditRequest(item))">تعديل</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(item.Id, AidRequestStatus.InitialApproved))">اعتماد مبدئي</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(item.Id, AidRequestStatus.NeedsSocialResearch))">بحث</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(item.Id, AidRequestStatus.CommitteeApproved))">اعتماد لجنة</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(item.Id, AidRequestStatus.RejectedWithNote))">ملاحظة</button>
                        <button class="secondary" @onclick="@(() => CreatePaymentOrderAsync(item.Id))">إنشاء أمر صرف</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<BeneficiaryResponse> beneficiaries = [];
    private List<BeneficiaryEntityResponse> entities = [];
    private List<AidRequestResponse> requests = [];
    private int? editingRequestId;
    private string beneficiaryIdText = string.Empty;
    private string entityIdText = string.Empty;
    private string? requestNumber;
    private string aidType = string.Empty;
    private decimal amount;
    private string description = string.Empty;
    private bool isExternal;
    private string statusText = string.Empty;
    private PaymentOrderType paymentOrderType = PaymentOrderType.Finance;
    private DateTime? paymentDueDate = DateTime.UtcNow.AddHours(3).Date;
    private string? socialNotes;
    private string? decisionNotes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        beneficiaries = await Beneficiaries.SearchAsync(status: BeneficiaryStatus.Active);
        entities = await Beneficiaries.GetEntitiesAsync(status: BeneficiaryEntityStatus.Active);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var status = Enum.TryParse<AidRequestStatus>(statusText, out var value) ? value : (AidRequestStatus?)null;
        requests = await Services.GetAidRequestsAsync(status);
    }

    private async Task SaveAsync()
    {
        var beneficiaryId = int.TryParse(beneficiaryIdText, out var beneficiaryValue) ? beneficiaryValue : (int?)null;
        var entityId = int.TryParse(entityIdText, out var entityValue) ? entityValue : (int?)null;
        var result = await Services.SaveAidRequestAsync(editingRequestId, new SaveAidRequestRequest(beneficiaryId, entityId, requestNumber, aidType, amount, description, isExternal));
        success = result.Success;
        message = result.Message;
        if (result.Success)
            ResetForm();
        await LoadAsync();
    }

    private void EditRequest(AidRequestResponse item)
    {
        editingRequestId = item.Id;
        beneficiaryIdText = item.BeneficiaryProfileId?.ToString() ?? string.Empty;
        entityIdText = item.BeneficiaryEntityId?.ToString() ?? string.Empty;
        requestNumber = item.RequestNumber;
        aidType = item.AidType;
        amount = item.Amount;
        description = item.Description;
        isExternal = item.IsExternal;
        socialNotes = item.SocialResearchNotes;
        decisionNotes = item.DecisionNotes;
        message = null;
    }

    private async Task DecideAsync(int id, AidRequestStatus status)
    {
        var result = await Services.DecideAidRequestAsync(id, status, socialNotes, decisionNotes);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private async Task CreatePaymentOrderAsync(int id)
    {
        var result = await Services.CreatePaymentOrderFromAidRequestAsync(id, paymentOrderType, paymentDueDate, decisionNotes);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void ResetForm()
    {
        editingRequestId = null;
        beneficiaryIdText = string.Empty;
        entityIdText = string.Empty;
        requestNumber = null;
        aidType = string.Empty;
        amount = 0;
        description = string.Empty;
        isExternal = false;
    }
}
