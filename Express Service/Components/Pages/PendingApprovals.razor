@page "/approvals/pending"
@attribute [Authorize]
@rendermode InteractiveServer
@inject TaskUiService Tasks

<h1 class="page-title">اعتمادات بانتظار الإجراء</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-paper-plane"></i><div><h2>إرسال طلب اعتماد</h2><p>إنشاء طلب اعتماد على مسار معرف مسبقاً.</p></div></div>
    <div class="form-grid">
        <label>المسار<select @bind="routeId">@foreach (var route in routes){<option value="@route.Id">@route.NameAr</option>}</select></label>
        <label>العنوان<input @bind="title" /></label>
        <label>نوع المرجع<input @bind="referenceType" /></label>
        <label>رقم المرجع<input type="number" @bind="referenceId" /></label>
        <label>ملاحظة القرار / سبب التفويض<input @bind="decisionComment" placeholder="سبب الإرجاع أو الرفض أو التفويض" /></label>
        <label>تفويض إلى<select @bind="delegateToUserId"><option value="">اختر مستخدماً</option>@foreach (var user in users){<option value="@user.Id">@user.FullName</option>}</select></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="CreateRequestAsync">إرسال طلب الاعتماد</button><button class="secondary" @onclick="LoadMineAsync">اعتماداتي فقط</button><button class="secondary" @onclick="LoadAllAsync">كل المعلّق</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-inbox"></i> الطلبات المعلقة</span></div>
    <table>
        <thead><tr><th>العنوان</th><th>المسار</th><th>مقدم الطلب</th><th>الخطوة</th><th>الموافق الحالي</th><th>المهلة / التصعيد</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var request in requests)
            {
                <tr>
                    <td>@request.Title</td>
                    <td>@request.RouteName</td>
                    <td>@request.RequestedByName</td>
                    <td>@request.CurrentStepOrder</td>
                    <td>@request.CurrentApproverName</td>
                    <td>@(request.DueAt?.ToString("yyyy/MM/dd HH:mm") ?? "—") @(request.EscalationCount > 0 ? $"(تصعيد {request.EscalationCount})" : string.Empty)</td>
                    <td>
                        <button class="primary" @onclick="() => DecideAsync(request.Id, ApprovalActionDecision.Approved)">اعتماد</button>
                        <button class="secondary" @onclick="() => DecideAsync(request.Id, ApprovalActionDecision.Returned)">إرجاع</button>
                        <button class="danger" @onclick="() => DecideAsync(request.Id, ApprovalActionDecision.Rejected)">رفض</button>
                        <button class="secondary" @onclick="() => DelegateAsync(request.Id)">تفويض</button>
                        @if (request.RequestedByUserId == Tasks.CurrentUserId){<button class="danger" @onclick="() => CancelAsync(request.Id)">إلغاء</button>}
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<ApprovalRouteResponse> routes = [];
    private List<UserPickerResponse> users = [];
    private List<ApprovalRequestResponse> requests = [];
    private int routeId;
    private string title = string.Empty;
    private string referenceType = "Task";
    private int? referenceId;
    private string? decisionComment;
    private string delegateToUserId = string.Empty;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        routes = await Tasks.GetApprovalRoutesAsync();
        users = await Tasks.GetUsersAsync();
        routeId = routes.FirstOrDefault()?.Id ?? 0;
        await LoadAllAsync();
    }

    private async Task LoadAllAsync() => requests = await Tasks.GetPendingApprovalsAsync(false);
    private async Task LoadMineAsync() => requests = await Tasks.GetPendingApprovalsAsync(true);

    private async Task CreateRequestAsync()
    {
        var result = await Tasks.CreateApprovalRequestAsync(new CreateApprovalRequestRequest(routeId, title, referenceType, referenceId));
        success = result.Success;
        message = result.Message;
        if (success)
            title = string.Empty;
        await LoadAllAsync();
    }

    private async Task DecideAsync(int id, ApprovalActionDecision decision)
    {
        var fallbackComment = decision switch
        {
            ApprovalActionDecision.Approved => "تم الاعتماد",
            ApprovalActionDecision.Returned => "تمت إعادة الطلب للمراجعة",
            _ => "تم الرفض"
        };
        var result = await Tasks.DecideApprovalAsync(id, decision, string.IsNullOrWhiteSpace(decisionComment) ? fallbackComment : decisionComment);
        success = result.Success;
        message = result.Message;
        await LoadAllAsync();
    }

    private async Task CancelAsync(int id)
    {
        var result = await Tasks.CancelApprovalAsync(id, decisionComment);
        success = result.Success;
        message = result.Message;
        await LoadAllAsync();
    }

    private async Task DelegateAsync(int id)
    {
        var result = await Tasks.DelegateApprovalAsync(id, delegateToUserId, decisionComment ?? string.Empty);
        success = result.Success;
        message = result.Message;
        await LoadAllAsync();
    }
}
