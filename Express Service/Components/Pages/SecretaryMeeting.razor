@page "/meetings/secretary"
@rendermode InteractiveServer

<section class="page-band">
    <h1>شاشة سكرتير المجلس</h1>
    <div class="tabs">
        <button class="@TabClass("cycle")" @onclick='() => activeTab = "cycle"'>بيانات المجلس والدورة</button>
        <button class="@TabClass("meeting")" @onclick='() => activeTab = "meeting"'>إعدادات الاجتماع</button>
        <button class="@TabClass("agenda")" @onclick='() => activeTab = "agenda"'>جدول الأعمال</button>
        <button class="@TabClass("members")" @onclick='() => activeTab = "members"'>المدعوون</button>
        <button class="@TabClass("send")" @onclick='() => activeTab = "send"'>إرسال الدعوات</button>
    </div>
</section>

@if (activeTab == "cycle")
{
    <section class="form-grid">
        <label>تاريخ بداية الدورة <input type="date" /></label>
        <label>تاريخ نهاية الدورة <input type="date" /></label>
        <label>عدد الدورات المتتالية <input type="number" min="1" max="4" value="1" /></label>
        <div class="rule-note">التحقق البرمجي: مدة الدورة لا تتجاوز سنة، والعدد لا يتجاوز 4، مع إغلاق الصلاحيات عند الانتهاء.</div>
    </section>
}
else if (activeTab == "meeting")
{
    <section class="form-grid">
        <label>تاريخ ووقت الاجتماع <input type="datetime-local" /></label>
        <label>مهلة قبول الدعوة بالأيام <input type="number" min="1" value="15" /></label>
        <label>نوع الاجتماع
            <select><option>عام</option><option>مجلس إدارة</option><option>جمعية عمومية</option></select>
        </label>
        <label>المكان أو منصة الاجتماع <input placeholder="المقر الرئيسي / Teams" /></label>
        <label class="check"><input type="checkbox" checked /> تفعيل التصويت</label>
        <label class="check"><input type="checkbox" /> اجتماع إلكتروني</label>
    </section>
}
else if (activeTab == "agenda")
{
    <section class="table-section">
        <button class="primary" @onclick="AddAgenda">إضافة بند</button>
        <table>
            <thead><tr><th>رقم</th><th>العنوان</th><th>الوصف</th><th>يحتاج قرار؟</th></tr></thead>
            <tbody>
                @foreach (var item in agenda)
                {
                    <tr><td>@item.Number</td><td>@item.Title</td><td>@item.Description</td><td><input type="checkbox" checked="@item.RequiresDecision" /></td></tr>
                }
            </tbody>
        </table>
    </section>
}
else if (activeTab == "members")
{
    <section class="table-section">
        <table>
            <thead><tr><th>العضو</th><th>سدد الرسوم</th><th>عضو داعم</th><th>النسبة التراكمية %</th></tr></thead>
            <tbody>
                @foreach (var member in members)
                {
                    <tr><td>@member</td><td><input type="checkbox" checked /></td><td><input type="checkbox" /></td><td><input type="number" min="1" max="100" value="1" /></td></tr>
                }
            </tbody>
        </table>
    </section>
}
else
{
    <section class="page-band">
        <h2>إرسال الدعوات</h2>
        <p>عند الضغط يتم إنشاء دعوة داخل التطبيق لكل عضو، وإضافة بريد رسمي إلى EmailOutbox بدون روابط خارجية.</p>
        <button class="primary">إرسال الدعوات</button>
    </section>
}

@code {
    private string activeTab = "cycle";
    private readonly List<string> members = ["سعيد", "محمد", "أحمد"];
    private readonly List<AgendaRow> agenda = [new(1, "افتتاح الاجتماع", "اعتماد جدول الأعمال", true)];

    private string TabClass(string tab) => activeTab == tab ? "active" : "";
    private void AddAgenda() => agenda.Add(new AgendaRow(agenda.Count + 1, "بند جديد", "وصف البند", false));
    private record AgendaRow(int Number, string Title, string Description, bool RequiresDecision);
}
