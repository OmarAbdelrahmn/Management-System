@page "/meetings/secretary"
@attribute [Authorize(Roles = "Admin,BoardSecretary")]
@rendermode InteractiveServer
@inject MeetingUiService UiService

<h1 class="page-title">شاشة سكرتير المجلس - تجهيز الاجتماع وإرسال الدعوات</h1>

<section class="news">
    <div class="marquee">
        <span>كل الأزرار في هذه الشاشة متصلة بالـ Backend: إنشاء اجتماع، إضافة بند جدول أعمال، وإرسال الدعوات داخل النظام والبريد.</span>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel">
        <div class="panel-body">
            <span class="status @(success ? "ok" : "bad")">@message</span>
        </div>
    </section>
}

<section class="panel">
    <div class="panel-heading">
        <i class="fa-solid fa-calendar-plus"></i>
        <div>
            <h2>إنشاء اجتماع جديد</h2>
            <p>اختر دورة مجلس فعالة ثم أدخل بيانات الاجتماع الحقيقية.</p>
        </div>
        <i class="fa-solid fa-angle-down"></i>
    </div>
    <div class="panel-body">
        @if (boardCycles.Count == 0)
        {
            <div class="rule-note">لا توجد دورة مجلس فعالة في قاعدة البيانات. أنشئ مجلساً ودورة أولاً من API أو شاشة الإدارة.</div>
        }
        else
        {
            <div class="form-grid">
                <label>دورة المجلس
                    <select @bind="createModel.BoardCycleId">
                        @foreach (var cycle in boardCycles)
                        {
                            <option value="@cycle.Id">@cycle.BoardName - الدورة @cycle.CycleNumber (@cycle.StartsAt:yyyy-MM-dd إلى @cycle.EndsAt:yyyy-MM-dd)</option>
                        }
                    </select>
                </label>
                <label>عنوان الاجتماع <input @bind="createModel.Title" /></label>
                <label>تاريخ ووقت الاجتماع <input type="datetime-local" @bind="createModel.ScheduledAt" /></label>
                <label>مهلة قبول الدعوة بالأيام <input type="number" min="1" @bind="createModel.AcceptanceDeadlineDays" /></label>
                <label>الرقم التسلسلي <input type="number" @bind="createModel.Serial" /></label>
                <label>نوع الاجتماع
                    <select @bind="createModel.Type">
                        <option value="@Domain.Entities.MeetingType.General">اجتماع عام</option>
                        <option value="@Domain.Entities.MeetingType.Board">اجتماع مجلس إدارة</option>
                        <option value="@Domain.Entities.MeetingType.Assembly">اجتماع جمعية عمومية</option>
                    </select>
                </label>
                <label>المكان <input @bind="createModel.Location" /></label>
                <label>المنصة <input @bind="createModel.Platform" /></label>
                <label>مدة الاجتماع بالدقائق <input type="number" @bind="createModel.DurationMinutes" /></label>
                <label>الحد الأدنى للحضور % <input type="number" min="1" max="100" @bind="createModel.MinimumAttendancePercentage" /></label>
                <label class="check"><input type="checkbox" @bind="createModel.HasVoting" /> تفعيل التصويت</label>
                <label class="check"><input type="checkbox" @bind="createModel.IsOnline" /> اجتماع إلكتروني</label>
            </div>
            <div class="toolbar" style="margin-top:12px">
                <button class="primary" @onclick="CreateMeetingAsync" disabled="@busy">حفظ الاجتماع</button>
            </div>
        }
    </div>
</section>

<section class="table-section">
    <div class="table-title">
        <span><i class="fa-solid fa-calendar-days"></i> الاجتماعات المجدولة من قاعدة البيانات</span>
        <button class="secondary" @onclick="LoadAsync">تحديث</button>
    </div>
    @if (meetings.Count == 0)
    {
        <div class="panel-body">لا توجد اجتماعات مجدولة حتى الآن.</div>
    }
    else
    {
        <table>
            <thead><tr><th>اختر</th><th>العنوان</th><th>التاريخ</th><th>النوع</th><th>الحالة</th><th>المكان/المنصة</th></tr></thead>
            <tbody>
                @foreach (var meeting in meetings)
                {
                    <tr>
                        <td><input type="radio" name="meeting" checked="@(selectedMeetingId == meeting.Id)" @onchange="() => selectedMeetingId = meeting.Id" /></td>
                        <td>@meeting.Title</td>
                        <td>@meeting.ScheduledAt</td>
                        <td>@meeting.Type</td>
                        <td><span class="status">@meeting.Status</span></td>
                        <td>@(meeting.IsOnline ? meeting.Platform : meeting.Location)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<section class="panel">
    <div class="panel-heading">
        <i class="fa-solid fa-list-ol"></i>
        <div>
            <h2>إضافة بند جدول أعمال للاجتماع المحدد</h2>
            <p>رقم البند يتولد تلقائياً من الخدمة.</p>
        </div>
        <i class="fa-solid fa-angle-down"></i>
    </div>
    <div class="panel-body">
        <div class="form-grid">
            <label>عنوان البند <input @bind="agendaTitle" /></label>
            <label style="grid-column: span 2">وصف البند <input @bind="agendaDescription" /></label>
            <label class="check"><input type="checkbox" @bind="agendaRequiresDecision" /> يحتاج قرار؟</label>
        </div>
        <div class="toolbar" style="margin-top:12px">
            <button class="primary" @onclick="AddAgendaAsync" disabled="@(busy || selectedMeetingId is null)">إضافة بند</button>
            <button class="secondary" @onclick="SendInvitationsAsync" disabled="@(busy || selectedMeetingId is null)">إرسال الدعوات</button>
        </div>
    </div>
</section>

@code {
    private bool busy;
    private bool success;
    private string? message;
    private int? selectedMeetingId;
    private List<BoardCycleOption> boardCycles = [];
    private List<MeetingListItemResponse> meetings = [];
    private CreateMeetingUiModel createModel = new();
    private string agendaTitle = string.Empty;
    private string agendaDescription = string.Empty;
    private bool agendaRequiresDecision = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        boardCycles = await UiService.GetBoardCyclesAsync();
        meetings = await UiService.GetScheduledMeetingsAsync();
        createModel.BoardCycleId = boardCycles.FirstOrDefault()?.Id ?? 0;
        selectedMeetingId ??= meetings.FirstOrDefault()?.Id;
    }

    private async Task CreateMeetingAsync()
    {
        busy = true;
        var request = new CreateMeetingRequest(
            createModel.BoardCycleId,
            createModel.Title,
            createModel.ScheduledAt,
            createModel.AcceptanceDeadlineDays,
            createModel.Serial,
            createModel.Type,
            null,
            Domain.Entities.MeetingImportance.Normal,
            createModel.HasVoting,
            createModel.IsOnline,
            createModel.Platform,
            createModel.Location,
            false,
            null,
            createModel.DurationMinutes,
            Domain.Entities.MeetingRepeatMode.None,
            null,
            createModel.MinimumAttendancePercentage,
            null,
            null);

        var result = await UiService.CreateMeetingAsync(request);
        success = result.Success;
        message = result.Message;
        if (result.Meeting is not null)
            selectedMeetingId = result.Meeting.Id;
        await LoadAsync();
        busy = false;
    }

    private async Task AddAgendaAsync()
    {
        if (selectedMeetingId is null)
            return;

        busy = true;
        var result = await UiService.AddAgendaItemAsync(selectedMeetingId.Value, new AddAgendaItemRequest(agendaTitle, agendaDescription, agendaRequiresDecision));
        success = result.Success;
        message = result.Message;
        if (success)
        {
            agendaTitle = string.Empty;
            agendaDescription = string.Empty;
        }
        busy = false;
    }

    private async Task SendInvitationsAsync()
    {
        if (selectedMeetingId is null)
            return;

        busy = true;
        var result = await UiService.SendInvitationsAsync(selectedMeetingId.Value);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
        busy = false;
    }

    private class CreateMeetingUiModel
    {
        public int BoardCycleId { get; set; }
        public string Title { get; set; } = string.Empty;
        public DateTime ScheduledAt { get; set; } = DateTime.Now.AddDays(7);
        public int AcceptanceDeadlineDays { get; set; } = 15;
        public int Serial { get; set; } = 1;
        public Domain.Entities.MeetingType Type { get; set; } = Domain.Entities.MeetingType.Board;
        public bool HasVoting { get; set; } = true;
        public bool IsOnline { get; set; }
        public string? Platform { get; set; }
        public string? Location { get; set; }
        public int? DurationMinutes { get; set; } = 90;
        public decimal MinimumAttendancePercentage { get; set; } = 50;
    }
}
