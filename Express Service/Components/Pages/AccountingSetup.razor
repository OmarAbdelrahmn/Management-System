@page "/accounting/setup"
@attribute [Authorize(Policy = "permission:system.accounting.finance_ledgers")]
@rendermode InteractiveServer
@inject AccountingUiService Accounting

<h1 class="page-title">إعدادات النظام المحاسبي</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-sitemap"></i><div><h2>الدليل والحسابات البنكية ومراكز التكلفة</h2><p>تهيئة وتصحيح الأساس المحاسبي وقيود اليومية.</p></div></div>
    <div class="form-grid compact">
        <label>كود الحساب<input @bind="accountCode" /></label>
        <label>اسم الحساب<input @bind="accountName" /></label>
        <label>نوع الحساب<select @bind="accountType"><option value="@AccountingAccountType.Asset">أصل</option><option value="@AccountingAccountType.Liability">التزام</option><option value="@AccountingAccountType.Equity">حقوق</option><option value="@AccountingAccountType.Income">إيراد</option><option value="@AccountingAccountType.Expense">مصروف</option></select></label>
        <label class="check-row"><input type="checkbox" @bind="accountActive" /> الحساب فعال</label>
        <label>البنك<input @bind="bankName" /></label>
        <label>اسم الحساب البنكي<input @bind="bankAccountName" /></label>
        <label>IBAN<input @bind="iban" /></label>
        <label>الرصيد الافتتاحي<input type="number" step="0.01" @bind="bankOpeningBalance" /></label>
        <label class="check-row"><input type="checkbox" @bind="bankActive" /> البنك فعال</label>
        <label>كود مركز التكلفة<input @bind="costCode" /></label>
        <label>اسم مركز التكلفة<input @bind="costName" /></label>
        <label class="check-row"><input type="checkbox" @bind="costActive" /> المركز فعال</label>
    </div>
    <div class="actions-row">
        <button class="primary" @onclick="SaveAccountAsync">@(editingAccountId.HasValue ? "تعديل حساب" : "حفظ حساب")</button>
        <button class="secondary" @onclick="SaveBankAsync">@(editingBankId.HasValue ? "تعديل بنك" : "حفظ بنك")</button>
        <button class="secondary" @onclick="SaveCostAsync">@(editingCostId.HasValue ? "تعديل مركز" : "حفظ مركز تكلفة")</button>
        <button class="secondary" @onclick="ResetSetupForms">تفريغ</button>
    </div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-calendar-days"></i><div><h2>الفترات المالية</h2><p>تمنع الفترة المغلقة أي تعديل أو ترحيل محاسبي بتاريخ يقع ضمنها.</p></div></div>
    <div class="form-grid compact">
        <label>اسم السنة المالية<input @bind="fiscalYearName" /></label>
        <label>من<input type="date" @bind="fiscalStartsAt" /></label>
        <label>إلى<input type="date" @bind="fiscalEndsAt" /></label>
        <label class="check-row"><input type="checkbox" @bind="fiscalIsClosed" /> إغلاق الفترة</label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveFiscalPeriodAsync">@(editingFiscalPeriodId.HasValue ? "حفظ الفترة" : "إضافة فترة مالية")</button><button class="secondary" @onclick="ResetFiscalPeriod">تفريغ</button></div>
    <div class="table-section" style="margin:14px 0 0"><table><thead><tr><th>السنة</th><th>البداية</th><th>النهاية</th><th>الحالة</th><th></th></tr></thead><tbody>@foreach (var period in fiscalPeriods){<tr><td>@period.FiscalYearName</td><td>@period.StartsAt.ToString("yyyy-MM-dd")</td><td>@period.EndsAt.ToString("yyyy-MM-dd")</td><td><span class="status @(period.IsClosed ? "bad" : "ok")">@(period.IsClosed ? "مغلقة" : "مفتوحة")</span></td><td><button class="secondary small" @onclick="() => EditFiscalPeriod(period)">تعديل</button></td></tr>}</tbody></table></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-book"></i><div><h2>@(editingLedgerId.HasValue ? "تعديل قيد يومية" : "قيد يومية")</h2><p>إضافة أو تصحيح قيد متوازن من حسابين.</p></div></div>
    <div class="form-grid compact">
        <label>رقم القيد<input @bind="ledgerNumber" placeholder="يولد تلقائياً عند تركه فارغاً" /></label>
        <label>تاريخ القيد<input type="date" @bind="ledgerDate" /></label>
        <label>الوصف<input @bind="ledgerDescription" /></label>
        <label>الحالة<input value="مسودة — يرحّل من زر الترحيل" disabled /></label>
        <label>مدين<select @bind="debitAccountId">@foreach (var account in accounts){<option value="@account.Id">@account.Code - @account.NameAr</option>}</select></label>
        <label>دائن<select @bind="creditAccountId">@foreach (var account in accounts){<option value="@account.Id">@account.Code - @account.NameAr</option>}</select></label>
        <label>مركز تكلفة<select @bind="ledgerCostCenterIdText"><option value="">بدون</option>@foreach (var center in costs){<option value="@center.Id">@center.Code - @center.NameAr</option>}</select></label>
        <label>المبلغ<input type="number" step="0.01" @bind="ledgerAmount" /></label>
        <label class="span-2">ملاحظات القيد<input @bind="ledgerNotes" /></label>
    </div>
    <div class="actions-row">
        <button class="primary" @onclick="SaveLedgerAsync">@(editingLedgerId.HasValue ? "حفظ التعديل" : "حفظ قيد")</button>
        @if (editingLedgerId.HasValue)
        {
            <button class="secondary" @onclick="ResetLedgerForm">إلغاء التعديل</button>
        }
        <button class="secondary" @onclick="LoadAsync">تحديث</button>
    </div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-table"></i> السجلات</span></div>
    <table>
        <thead><tr><th>النوع</th><th>الكود/الرقم</th><th>الاسم/الوصف</th><th>الحالة</th><th>إجراءات</th></tr></thead>
        <tbody>
            @foreach (var account in accounts)
            {
                <tr><td>حساب</td><td>@account.Code</td><td>@account.NameAr</td><td>@account.AccountType</td><td><button class="secondary small" @onclick="() => EditAccount(account)">تعديل</button></td></tr>
            }
            @foreach (var bank in banks)
            {
                <tr><td>بنك</td><td>@bank.Iban</td><td>@bank.BankName - @bank.AccountName</td><td>@bank.OpeningBalance</td><td><button class="secondary small" @onclick="() => EditBank(bank)">تعديل</button></td></tr>
            }
            @foreach (var center in costs)
            {
                <tr><td>مركز</td><td>@center.Code</td><td>@center.NameAr</td><td>@center.IsActive</td><td><button class="secondary small" @onclick="() => EditCost(center)">تعديل</button></td></tr>
            }
            @foreach (var ledger in ledgers)
            {
                <tr><td>قيد</td><td>@ledger.EntryNumber</td><td>@ledger.Description</td><td><span class="status">@ledger.Status</span></td><td><button class="secondary small" @onclick="() => EditLedger(ledger)" disabled="@(ledger.Status is "Posted" or "Approved" or "Closed" or "Canceled" or "Archived")">تعديل</button><button class="secondary small" @onclick="() => SelectLedger(ledger)">تفاصيل</button>@if (ledger.Status == "Draft"){<button class="primary small" @onclick="() => SetLedgerPostingAsync(ledger.Id, true)">ترحيل نهائي</button>}</td></tr>
            }
        </tbody>
    </table>
</section>

@if (selectedLedger is not null)
{
    <section class="table-section">
        <div class="table-title"><span><i class="fa-solid fa-scale-balanced"></i> تفاصيل القيد: @selectedLedger.EntryNumber</span></div>
        <table>
            <thead><tr><th>الحساب</th><th>مركز التكلفة</th><th>مدين</th><th>دائن</th><th>ملاحظات</th></tr></thead>
            <tbody>
                @foreach (var line in selectedLedger.Lines)
                {
                    <tr>
                        <td>@line.AccountCode - @line.AccountNameAr</td>
                        <td>@(line.CostCenterCode is null ? "-" : $"{line.CostCenterCode} - {line.CostCenterNameAr}")</td>
                        <td>@line.Debit</td>
                        <td>@line.Credit</td>
                        <td>@(line.Notes ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
    <AttachmentPanel EntityType="LedgerEntry" EntityId="@selectedLedger.Id" />
}

@code {
    private List<FinanceAccountResponse> accounts = [];
    private List<FinanceBankAccountResponse> banks = [];
    private List<FinanceCostCenterResponse> costs = [];
    private List<LedgerEntryResponse> ledgers = [];
    private List<FiscalPeriodResponse> fiscalPeriods = [];
    private LedgerEntryResponse? selectedLedger;
    private string accountCode = string.Empty;
    private string accountName = string.Empty;
    private AccountingAccountType accountType = AccountingAccountType.Asset;
    private bool accountActive = true;
    private int? editingAccountId;
    private string bankName = string.Empty;
    private string bankAccountName = string.Empty;
    private string iban = string.Empty;
    private decimal bankOpeningBalance;
    private bool bankActive = true;
    private int? editingBankId;
    private string costCode = string.Empty;
    private string costName = string.Empty;
    private bool costActive = true;
    private int? editingCostId;
    private string? ledgerNumber;
    private DateTime ledgerDate = DateTime.UtcNow.AddHours(3).Date;
    private string ledgerDescription = string.Empty;
    private AccountingRecordStatus ledgerStatus = AccountingRecordStatus.Draft;
    private int debitAccountId;
    private int creditAccountId;
    private string ledgerCostCenterIdText = string.Empty;
    private decimal ledgerAmount;
    private string? ledgerNotes;
    private int? editingLedgerId;
    private bool success;
    private string? message;
    private int? editingFiscalPeriodId;
    private string fiscalYearName = string.Empty;
    private DateTime fiscalStartsAt = new(DateTime.UtcNow.Year, 1, 1);
    private DateTime fiscalEndsAt = new(DateTime.UtcNow.Year, 12, 31);
    private bool fiscalIsClosed;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        accounts = await Accounting.GetAccountsAsync();
        banks = await Accounting.GetBankAccountsAsync();
        costs = await Accounting.GetCostCentersAsync();
        ledgers = await Accounting.GetLedgerEntriesAsync();
        fiscalPeriods = await Accounting.GetFiscalPeriodsAsync();
        if (selectedLedger is not null)
            selectedLedger = ledgers.FirstOrDefault(x => x.Id == selectedLedger.Id);
        debitAccountId = debitAccountId == 0 ? accounts.FirstOrDefault()?.Id ?? 0 : debitAccountId;
        creditAccountId = creditAccountId == 0 ? accounts.Skip(1).FirstOrDefault()?.Id ?? debitAccountId : creditAccountId;
    }

    private async Task SaveAccountAsync()
    {
        var result = await Accounting.SaveAccountAsync(editingAccountId, new SaveFinanceAccountRequest(accountCode, accountName, accountType, null, accountActive));
        success = result.Success;
        message = result.Message;
        if (success)
            ResetAccountForm();
        await LoadAsync();
    }

    private async Task SaveBankAsync()
    {
        var result = await Accounting.SaveBankAccountAsync(editingBankId, new SaveFinanceBankAccountRequest(bankName, bankAccountName, iban, bankOpeningBalance, bankActive));
        success = result.Success;
        message = result.Message;
        if (success)
            ResetBankForm();
        await LoadAsync();
    }

    private async Task SaveCostAsync()
    {
        var result = await Accounting.SaveCostCenterAsync(editingCostId, new SaveFinanceCostCenterRequest(costCode, costName, costActive));
        success = result.Success;
        message = result.Message;
        if (success)
            ResetCostForm();
        await LoadAsync();
    }

    private async Task SaveLedgerAsync()
    {
        var costCenterId = int.TryParse(ledgerCostCenterIdText, out var value) ? value : (int?)null;
        var lines = new List<SaveLedgerLineRequest>
        {
            new(debitAccountId, costCenterId, ledgerAmount, 0, ledgerNotes),
            new(creditAccountId, costCenterId, 0, ledgerAmount, ledgerNotes)
        };
        var result = await Accounting.SaveLedgerEntryAsync(editingLedgerId, new SaveLedgerEntryRequest(ledgerNumber, ledgerDate, ledgerDescription, ledgerStatus, lines));
        success = result.Success;
        message = result.Message;
        if (success)
            ResetLedgerForm();
        await LoadAsync();
    }

    private async Task SaveFiscalPeriodAsync()
    {
        var result = await Accounting.SaveFiscalPeriodAsync(editingFiscalPeriodId, new SaveFiscalPeriodRequest(fiscalYearName, fiscalStartsAt, fiscalEndsAt, fiscalIsClosed));
        success = result.Success;
        message = result.Message;
        if (success) ResetFiscalPeriod();
        await LoadAsync();
    }

    private async Task SetLedgerPostingAsync(int id, bool isPosted)
    {
        var result = await Accounting.SetLedgerPostingAsync(id, isPosted);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void EditFiscalPeriod(FiscalPeriodResponse period)
    {
        editingFiscalPeriodId = period.Id;
        fiscalYearName = period.FiscalYearName;
        fiscalStartsAt = period.StartsAt;
        fiscalEndsAt = period.EndsAt;
        fiscalIsClosed = period.IsClosed;
    }

    private void ResetFiscalPeriod()
    {
        editingFiscalPeriodId = null;
        fiscalYearName = string.Empty;
        fiscalStartsAt = new(DateTime.UtcNow.Year, 1, 1);
        fiscalEndsAt = new(DateTime.UtcNow.Year, 12, 31);
        fiscalIsClosed = false;
    }

    private void EditAccount(FinanceAccountResponse account)
    {
        editingAccountId = account.Id;
        accountCode = account.Code;
        accountName = account.NameAr;
        accountType = Enum.TryParse<AccountingAccountType>(account.AccountType, out var parsedType) ? parsedType : AccountingAccountType.Asset;
        accountActive = account.IsActive;
    }

    private void EditBank(FinanceBankAccountResponse bank)
    {
        editingBankId = bank.Id;
        bankName = bank.BankName;
        bankAccountName = bank.AccountName;
        iban = bank.Iban;
        bankOpeningBalance = bank.OpeningBalance;
        bankActive = bank.IsActive;
    }

    private void EditCost(FinanceCostCenterResponse center)
    {
        editingCostId = center.Id;
        costCode = center.Code;
        costName = center.NameAr;
        costActive = center.IsActive;
    }

    private void EditLedger(LedgerEntryResponse ledger)
    {
        editingLedgerId = ledger.Id;
        ledgerNumber = ledger.EntryNumber;
        ledgerDate = ledger.EntryDate;
        ledgerDescription = ledger.Description;
        ledgerStatus = Enum.TryParse<AccountingRecordStatus>(ledger.Status, out var parsedStatus) ? parsedStatus : AccountingRecordStatus.Draft;
        var debitLine = ledger.Lines.FirstOrDefault(x => x.Debit > 0);
        var creditLine = ledger.Lines.FirstOrDefault(x => x.Credit > 0);
        debitAccountId = debitLine?.FinanceAccountId ?? accounts.FirstOrDefault()?.Id ?? 0;
        creditAccountId = creditLine?.FinanceAccountId ?? accounts.Skip(1).FirstOrDefault()?.Id ?? debitAccountId;
        ledgerCostCenterIdText = debitLine?.FinanceCostCenterId?.ToString() ?? creditLine?.FinanceCostCenterId?.ToString() ?? string.Empty;
        ledgerAmount = debitLine?.Debit ?? creditLine?.Credit ?? 0;
        ledgerNotes = debitLine?.Notes ?? creditLine?.Notes;
        selectedLedger = ledger;
    }

    private void ResetSetupForms()
    {
        ResetAccountForm();
        ResetBankForm();
        ResetCostForm();
    }

    private void ResetAccountForm()
    {
        editingAccountId = null;
        accountCode = string.Empty;
        accountName = string.Empty;
        accountType = AccountingAccountType.Asset;
        accountActive = true;
    }

    private void ResetBankForm()
    {
        editingBankId = null;
        bankName = string.Empty;
        bankAccountName = string.Empty;
        iban = string.Empty;
        bankOpeningBalance = 0;
        bankActive = true;
    }

    private void ResetCostForm()
    {
        editingCostId = null;
        costCode = string.Empty;
        costName = string.Empty;
        costActive = true;
    }

    private void ResetLedgerForm()
    {
        editingLedgerId = null;
        ledgerNumber = null;
        ledgerDate = DateTime.UtcNow.AddHours(3).Date;
        ledgerDescription = string.Empty;
        ledgerStatus = AccountingRecordStatus.Draft;
        ledgerCostCenterIdText = string.Empty;
        ledgerAmount = 0;
        ledgerNotes = null;
    }

    private void SelectLedger(LedgerEntryResponse ledger) => selectedLedger = ledger;
}
