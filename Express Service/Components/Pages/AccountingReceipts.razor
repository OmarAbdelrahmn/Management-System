@page "/accounting/receipts"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject AccountingUiService Accounting

<h1 class="page-title">المقبوضات والمطالبات الآجلة</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="form-grid compact">
        <label>نوع السند<select @bind="receiptKind"><option value="@ReceiptVoucherKind.Donation">تبرع عام</option><option value="@ReceiptVoucherKind.Project">مشروع</option><option value="@ReceiptVoucherKind.Beneficiary">مستفيد</option><option value="@ReceiptVoucherKind.Sponsorship">كفالة</option><option value="@ReceiptVoucherKind.Program">برنامج</option><option value="@ReceiptVoucherKind.Generic">متنوع</option><option value="@ReceiptVoucherKind.Return">مرتجع</option></select></label>
        <label>الدافع<input @bind="payerName" /></label>
        <label>المبلغ<input type="number" step="0.01" @bind="amount" /></label>
        <label>المرجع<input @bind="reference" /></label>
        <label>مطالبة آجل - المدين<input @bind="debtorName" /></label>
        <label>تاريخ الاستحقاق<input type="date" @bind="dueDate" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveReceiptAsync">حفظ سند قبض</button><button class="secondary" @onclick="SaveDeferredAsync">حفظ مطالبة آجل</button><button class="secondary" @onclick="ReceiveDeferredAsync">استلام أول مطالبة</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-receipt"></i> المقبوضات</span></div>
    <table>
        <thead><tr><th>النوع</th><th>الرقم</th><th>الطرف</th><th>المبلغ</th><th>الحالة</th></tr></thead>
        <tbody>
            @foreach (var receipt in receipts){<tr><td>@receipt.Kind</td><td>@receipt.ReceiptNumber</td><td>@receipt.PayerName</td><td>@receipt.Amount</td><td>@receipt.Status</td></tr>}
            @foreach (var item in deferred){<tr><td>آجل @item.Kind</td><td>@item.ReceivableNumber</td><td>@item.DebtorName</td><td>@item.RemainingAmount</td><td>@item.Status</td></tr>}
        </tbody>
    </table>
</section>

@code {
    private List<ReceiptVoucherResponse> receipts = [];
    private List<DeferredReceivableResponse> deferred = [];
    private ReceiptVoucherKind receiptKind = ReceiptVoucherKind.Donation;
    private string payerName = string.Empty;
    private decimal amount;
    private string? reference;
    private string debtorName = string.Empty;
    private DateTime dueDate = DateTime.UtcNow.AddHours(3).Date.AddMonths(1);
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync(){ receipts = await Accounting.GetReceiptsAsync(); deferred = await Accounting.GetDeferredReceivablesAsync(); }
    private async Task SaveReceiptAsync(){ var r = await Accounting.SaveReceiptAsync(null, new SaveReceiptVoucherRequest(null, receiptKind, DateTime.UtcNow.AddHours(3), amount, payerName, reference, AccountingRecordStatus.Posted, null)); success = r.Success; message = r.Message; await LoadAsync(); }
    private async Task SaveDeferredAsync(){ var r = await Accounting.SaveDeferredReceivableAsync(null, new SaveDeferredReceivableRequest(null, DeferredReceivableKind.Generic, debtorName, amount, dueDate, null)); success = r.Success; message = r.Message; await LoadAsync(); }
    private async Task ReceiveDeferredAsync(){ var item = deferred.FirstOrDefault(); if (item is null){ success = false; message = "لا توجد مطالبة."; return; } var r = await Accounting.ReceiveDeferredReceivableAsync(item.Id, item.Amount); success = r.Success; message = r.Message; await LoadAsync(); }
}
