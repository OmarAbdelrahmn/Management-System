@page "/documentation-archive/mail"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject DocumentationArchiveUiService Documentation

<h1 class="page-title">البريد الصادر و الوارد</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-envelope-open-text"></i><div><h2>سجل بريد</h2><p>إضافة وتحديث الصادر والوارد، الرسائل التي تحتاج إلى رد، الحذف، الموافقة على الحذف، والباركود.</p></div></div>
    <div class="form-grid compact">
        <label>رقم البريد<input @bind="mailNumber" /></label>
        <label>الاتجاه<select @bind="direction"><option value="@CorrespondenceDirection.Outgoing">صادر</option><option value="@CorrespondenceDirection.Incoming">وارد</option></select></label>
        <label>الموضوع<input @bind="subject" /></label>
        <label>الجهة<input @bind="partyName" /></label>
        <label>تاريخ البريد<input type="date" @bind="mailDate" /></label>
        <label>الباركود<input @bind="barcodeValue" /></label>
        <label>الحالة<select @bind="mailStatus"><option value="@CorrespondenceStatus.Draft">مسودة</option><option value="@CorrespondenceStatus.Registered">مسجل</option><option value="@CorrespondenceStatus.NeedsReply">بحاجة إلى رد</option><option value="@CorrespondenceStatus.Replied">تم الرد</option><option value="@CorrespondenceStatus.Completed">مكتمل</option><option value="@CorrespondenceStatus.Removed">محذوف</option><option value="@CorrespondenceStatus.PendingRemovalApproval">بانتظار اعتماد الحذف</option></select></label>
        <label class="span-2">ملاحظات<input @bind="notes" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveMailAsync">حفظ البريد</button><button class="secondary" @onclick="LoadIncomingAsync">الوارد</button><button class="secondary" @onclick="LoadOutgoingAsync">الصادر</button><button class="secondary" @onclick="LoadNeedsReplyAsync">تحتاج رد</button><button class="secondary" @onclick="LoadAsync">كل البريد</button></div>
</section>

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-list-check"></i><div><h2>معاملة بريد</h2><p>إنشاء معاملات الرسائل، متابعة المفتوح والمنتهي، وقاعدة بيانات المعاملات الداخلية.</p></div></div>
    <div class="form-grid compact">
        <label>سجل البريد<select @bind="operationMailId"><option value="0">اختر سجل بريد</option>@foreach (var item in correspondence){<option value="@item.Id">@item.MailNumber - @item.Subject</option>}</select></label>
        <label>رقم المعاملة<input @bind="operationNumber" /></label>
        <label>العنوان<input @bind="operationTitle" /></label>
        <label>المسند إليه<input @bind="assignedTo" /></label>
        <label>تاريخ الاستحقاق<input type="date" @bind="dueDate" /></label>
        <label>الحالة<select @bind="operationStatus"><option value="@CorrespondenceOperationStatus.Open">مفتوحة</option><option value="@CorrespondenceOperationStatus.Completed">منتهية</option><option value="@CorrespondenceOperationStatus.Cancelled">ملغاة</option></select></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveOperationAsync">حفظ المعاملة</button><button class="secondary" @onclick="LoadOpenOperationsAsync">المفتوحة</button><button class="secondary" @onclick="LoadCompletedOperationsAsync">المنتهية</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-database"></i> قاعدة بيانات الصادر و الوارد</span></div>
    <table>
        <thead><tr><th>الرقم</th><th>الاتجاه</th><th>الموضوع</th><th>الجهة</th><th>الحالة</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var item in correspondence)
            {
                <tr>
                    <td>@item.MailNumber<br />@item.BarcodeValue</td><td>@item.Direction</td><td>@item.Subject</td><td>@item.PartyName<br />@item.MailDate.ToString("yyyy-MM-dd")</td><td>@item.Status<br />@item.OperationsCount معاملات</td>
                    <td>
                        <button class="secondary" @onclick="@(() => ChangeMailStatusAsync(item.Id, CorrespondenceStatus.NeedsReply))">بحاجة رد</button>
                        <button class="secondary" @onclick="@(() => ChangeMailStatusAsync(item.Id, CorrespondenceStatus.Completed))">إكمال</button>
                        <button class="secondary" @onclick="@(() => ChangeMailStatusAsync(item.Id, CorrespondenceStatus.PendingRemovalApproval))">طلب حذف</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-list-check"></i> معاملات البريد</span></div>
    <table>
        <thead><tr><th>المعاملة</th><th>البريد</th><th>المسؤول</th><th>الاستحقاق</th><th>الحالة</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var item in operations)
            {
                <tr><td>@item.OperationNumber<br />@item.Title</td><td>@item.MailNumber</td><td>@item.AssignedTo</td><td>@item.DueDate?.ToString("yyyy-MM-dd")</td><td>@item.Status<br />@item.Notes</td><td><button class="secondary" @onclick="@(() => CompleteOperationAsync(item.Id))">إكمال</button></td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<CorrespondenceRecordResponse> correspondence = [];
    private List<CorrespondenceOperationResponse> operations = [];
    private string mailNumber = $"MAIL-{DateTime.UtcNow:yyyyMMddHHmm}";
    private CorrespondenceDirection direction = CorrespondenceDirection.Outgoing;
    private string subject = string.Empty;
    private string partyName = string.Empty;
    private DateTime mailDate = DateTime.UtcNow.AddHours(3).Date;
    private string? barcodeValue;
    private CorrespondenceStatus mailStatus = CorrespondenceStatus.Registered;
    private string? notes;
    private int operationMailId;
    private string operationNumber = $"OP-{DateTime.UtcNow:yyyyMMddHHmm}";
    private string operationTitle = string.Empty;
    private string? assignedTo;
    private DateTime? dueDate = DateTime.UtcNow.AddHours(3).Date.AddDays(7);
    private CorrespondenceOperationStatus operationStatus = CorrespondenceOperationStatus.Open;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync(){ correspondence = await Documentation.GetCorrespondenceAsync(); operations = await Documentation.GetOperationsAsync(); }
    private async Task LoadIncomingAsync() => correspondence = await Documentation.GetCorrespondenceAsync(CorrespondenceDirection.Incoming);
    private async Task LoadOutgoingAsync() => correspondence = await Documentation.GetCorrespondenceAsync(CorrespondenceDirection.Outgoing);
    private async Task LoadNeedsReplyAsync() => correspondence = await Documentation.GetCorrespondenceAsync(status: CorrespondenceStatus.NeedsReply);
    private async Task LoadOpenOperationsAsync() => operations = await Documentation.GetOperationsAsync(CorrespondenceOperationStatus.Open);
    private async Task LoadCompletedOperationsAsync() => operations = await Documentation.GetOperationsAsync(CorrespondenceOperationStatus.Completed);

    private async Task SaveMailAsync()
    {
        var result = await Documentation.SaveCorrespondenceAsync(null, new SaveCorrespondenceRecordRequest(mailNumber, direction, subject, partyName, mailDate, barcodeValue, mailStatus, notes));
        success = result.Success;
        message = result.Message;
        if (success) mailNumber = $"MAIL-{DateTime.UtcNow:yyyyMMddHHmmss}";
        await LoadAsync();
    }

    private async Task SaveOperationAsync()
    {
        var result = await Documentation.SaveOperationAsync(null, new SaveCorrespondenceOperationRequest(operationMailId, operationNumber, operationTitle, assignedTo, dueDate, operationStatus, notes));
        success = result.Success;
        message = result.Message;
        if (success) operationNumber = $"OP-{DateTime.UtcNow:yyyyMMddHHmmss}";
        await LoadAsync();
    }

    private async Task ChangeMailStatusAsync(int id, CorrespondenceStatus status)
    {
        var result = await Documentation.UpdateCorrespondenceStatusAsync(id, status, notes);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private async Task CompleteOperationAsync(int id)
    {
        var result = await Documentation.CompleteOperationAsync(id, notes);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }
}
