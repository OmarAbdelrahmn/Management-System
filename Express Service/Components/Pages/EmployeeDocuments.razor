@page "/hr/documents"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject HumanResourceUiService HR

<h1 class="page-title">مستندات الموظفين</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-file-lines"></i><div><h2>إضافة مستند</h2><p>تسجيل عقود وملفات الموظفين ومواعيد الانتهاء.</p></div></div>
    <div class="form-grid">
        <label>الموظف<select @bind="employeeId">@foreach (var employee in employees){<option value="@employee.Id">@employee.FullName</option>}</select></label>
        <label>العنوان<input @bind="title" /></label>
        <label>نوع المستند<input @bind="documentType" /></label>
        <label>مسار الملف<input @bind="filePath" /></label>
        <label>تاريخ الانتهاء<input type="date" @bind="expiresAt" /></label>
        <label class="span-2">ملاحظات<textarea @bind="notes"></textarea></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveAsync">إضافة المستند</button><button class="secondary" @onclick="LoadAsync">تحديث</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-folder-open"></i> المستندات</span></div>
    <table>
        <thead><tr><th>الموظف</th><th>العنوان</th><th>النوع</th><th>المسار</th><th>ينتهي في</th><th>ملاحظات</th></tr></thead>
        <tbody>
            @foreach (var item in documents)
            {
                <tr><td>@item.EmployeeName</td><td>@item.Title</td><td>@item.DocumentType</td><td>@item.FilePath</td><td>@item.ExpiresAt?.ToString("yyyy-MM-dd")</td><td>@item.Notes</td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<EmployeeResponse> employees = [];
    private List<EmployeeDocumentResponse> documents = [];
    private int employeeId;
    private string title = string.Empty;
    private string documentType = "عقد";
    private string? filePath;
    private DateTime? expiresAt;
    private string? notes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        employees = await HR.SearchEmployeesAsync(null, null, null, null);
        employeeId = employees.FirstOrDefault()?.Id ?? 0;
        await LoadAsync();
    }

    private async Task LoadAsync() => documents = await HR.GetDocumentsAsync();

    private async Task SaveAsync()
    {
        var result = await HR.AddDocumentAsync(new AddEmployeeDocumentRequest(employeeId, title, documentType, filePath, expiresAt, notes));
        success = result.Success;
        message = result.Message;
        if (success)
        {
            title = string.Empty;
            filePath = null;
            expiresAt = null;
            notes = null;
        }
        await LoadAsync();
    }
}
