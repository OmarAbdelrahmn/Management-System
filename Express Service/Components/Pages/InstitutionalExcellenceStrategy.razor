@page "/institutional-excellence/strategy"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject InstitutionalExcellenceUiService Excellence

<h1 class="page-title">إدارة الخطة الإستراتيجية</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-map"></i><div><h2>خطة إستراتيجية</h2><p>إدارة الخطط ومتغيراتها وقيم التحقق المؤتمتة.</p></div></div>
    <div class="form-grid compact">
        <label>عنوان الخطة<input @bind="planTitle" /></label>
        <label>البداية<input type="date" @bind="startDate" /></label>
        <label>النهاية<input type="date" @bind="endDate" /></label>
        <label>الحالة<select @bind="planStatus"><option value="@ExcellenceRecordStatus.Draft">مسودة</option><option value="@ExcellenceRecordStatus.Active">نشطة</option><option value="@ExcellenceRecordStatus.Completed">مكتملة</option><option value="@ExcellenceRecordStatus.Archived">مؤرشفة</option></select></label>
        <label class="span-2">الرؤية<input @bind="vision" /></label>
        <label class="span-2">الرسالة<input @bind="mission" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SavePlanAsync">@(editingPlanId.HasValue ? "تحديث الخطة" : "حفظ الخطة")</button><button class="secondary" @onclick="ResetPlan">تفريغ</button><button class="secondary" @onclick="FetchVariablesAsync">تحديث قيم التحقق المؤتمتة لأول خطة</button></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-sitemap"></i><div><h2>مناظير وأهداف الخطة</h2><p>إدارة مناظير الخطة، الأهداف الإستراتيجية، وتناغم رؤية 2030 والتنمية المستدامة.</p></div></div>
    <div class="form-grid compact">
        <label>الخطة<select @bind="perspectivePlanId"><option value="0">اختر الخطة</option>@foreach (var plan in plans){<option value="@plan.Id">@plan.Title</option>}</select></label>
        <label>اسم المنظور<input @bind="perspectiveName" /></label>
        <label>ترتيب المنظور<input type="number" @bind="perspectiveSortOrder" /></label>
        <label>المنظور<select @bind="goalPerspectiveId"><option value="0">اختر المنظور</option>@foreach (var perspective in perspectives){<option value="@perspective.Id">@perspective.Name</option>}</select></label>
        <label>الهدف<input @bind="goalTitle" /></label>
        <label>ترتيب الهدف<input type="number" @bind="goalSortOrder" /></label>
        <label class="span-2">تناغم رؤية 2030<input @bind="visionAlignment" /></label>
        <label class="span-2">تناغم التنمية المستدامة<input @bind="sustainabilityAlignment" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SavePerspectiveAsync">@(editingPerspectiveId.HasValue ? "تحديث منظور" : "حفظ منظور")</button><button class="secondary" @onclick="SaveGoalAsync">@(editingGoalId.HasValue ? "تحديث هدف" : "حفظ هدف")</button><button class="secondary" @onclick="ResetPerspectiveGoal">تفريغ</button></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-chart-line"></i><div><h2>المؤشرات والمتغيرات</h2><p>إدارة المؤشرات الرئيسية والفرعية والمملوكة ومؤشرات المشاريع والبرامج.</p></div></div>
    <div class="form-grid compact">
        <label>الخطة<select @bind="indicatorPlanId"><option value="0">اختر الخطة</option>@foreach (var plan in plans){<option value="@plan.Id">@plan.Title</option>}</select></label>
        <label>الهدف<select @bind="indicatorGoalId"><option value="">بدون</option>@foreach (var goal in goals){<option value="@goal.Id">@goal.Title</option>}</select></label>
        <label>المؤشر الأب<select @bind="parentIndicatorId"><option value="">بدون</option>@foreach (var indicator in indicators.Where(x => x.Kind == StrategicIndicatorKind.Main.ToString())){<option value="@indicator.Id">@indicator.Name</option>}</select></label>
        <label>نوع المؤشر<select @bind="indicatorKind"><option value="@StrategicIndicatorKind.Main">رئيسي</option><option value="@StrategicIndicatorKind.Sub">فرعي</option><option value="@StrategicIndicatorKind.Owned">مملوك</option><option value="@StrategicIndicatorKind.Project">مشروع</option><option value="@StrategicIndicatorKind.Program">برنامج</option></select></label>
        <label>اسم المؤشر<input @bind="indicatorName" /></label>
        <label>المستهدف<input type="number" step="0.01" @bind="indicatorTarget" /></label>
        <label>المتحقق<input type="number" step="0.01" @bind="indicatorActual" /></label>
        <label>الوحدة<input @bind="indicatorUnit" /></label>
        <label>المالك<input @bind="indicatorOwner" /></label>
        <label>مشروع مرتبط<input @bind="relatedProject" /></label>
        <label>برنامج مرتبط<input @bind="relatedProgram" /></label>
        <label>الحالة<select @bind="indicatorStatus"><option value="@StrategicIndicatorStatus.Draft">مسودة</option><option value="@StrategicIndicatorStatus.Active">نشط</option><option value="@StrategicIndicatorStatus.Achieved">محقق</option><option value="@StrategicIndicatorStatus.AtRisk">متعثر</option><option value="@StrategicIndicatorStatus.Closed">مغلق</option></select></label>
        <label>متغير<input @bind="variableName" /></label>
        <label>قيمة المتغير<input type="number" step="0.01" @bind="variableValue" /></label>
        <label><input type="checkbox" @bind="isAutomated" /> مؤتمت</label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveIndicatorAsync">@(editingIndicatorId.HasValue ? "تحديث مؤشر" : "حفظ مؤشر")</button><button class="secondary" @onclick="SaveVariableAsync">@(editingVariableId.HasValue ? "تحديث متغير" : "حفظ متغير")</button><button class="secondary" @onclick="ApplyVariablesAsync">تطبيق المتغيرات</button><button class="secondary" @onclick="ResetIndicatorVariable">تفريغ</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-diagram-project"></i> خارطة وشجرة الخطة الإستراتيجية</span></div>
    <table>
        <thead><tr><th>الخطة</th><th>المناظير</th><th>المؤشرات</th><th>الإنجاز</th><th>الحالة</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var plan in plans)
            {
                <tr><td>@plan.Title<br />@plan.StartDate.ToString("yyyy-MM-dd") - @plan.EndDate.ToString("yyyy-MM-dd")</td><td>@plan.PerspectivesCount</td><td>@plan.IndicatorsCount</td><td>@plan.AchievementPercent%</td><td>@plan.Status</td><td><button class="secondary" @onclick="@(() => EditPlan(plan))">تعديل</button><button class="secondary" @onclick="@(() => ChangePlanStatusAsync(plan, ExcellenceRecordStatus.Completed))">إكمال</button><button class="secondary" @onclick="@(() => ChangePlanStatusAsync(plan, ExcellenceRecordStatus.Archived))">أرشفة</button></td></tr>
            }
        </tbody>
    </table>
</section>

<section class="table-section" style="margin-top:14px">
    <div class="table-title"><span><i class="fa-solid fa-sitemap"></i> المناظير والأهداف</span></div>
    <table>
        <thead><tr><th>النوع</th><th>الخطة/المنظور</th><th>العنوان</th><th>الترتيب</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var perspective in perspectives)
            {
                <tr><td>منظور</td><td>@perspective.PlanTitle</td><td>@perspective.Name</td><td>@perspective.SortOrder</td><td><button class="secondary" @onclick="@(() => EditPerspective(perspective))">تعديل</button></td></tr>
            }
            @foreach (var goal in goals)
            {
                <tr><td>هدف</td><td>@goal.PerspectiveName</td><td>@goal.Title<br />@goal.Vision2030Alignment</td><td>@goal.SortOrder</td><td><button class="secondary" @onclick="@(() => EditGoal(goal))">تعديل</button></td></tr>
            }
        </tbody>
    </table>
</section>

<section class="table-section" style="margin-top:14px">
    <div class="table-title"><span><i class="fa-solid fa-chart-simple"></i> المؤشرات</span></div>
    <table>
        <thead><tr><th>المؤشر</th><th>النوع</th><th>الهدف</th><th>المستهدف/المتحقق</th><th>الإنجاز</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var indicator in indicators)
            {
                <tr><td>@indicator.Name<br />@indicator.OwnerName</td><td>@indicator.Kind</td><td>@indicator.GoalTitle</td><td>@indicator.TargetValue / @indicator.ActualValue @indicator.Unit</td><td>@indicator.AchievementPercent%</td><td><button class="secondary" @onclick="@(() => EditIndicator(indicator))">تعديل</button><button class="secondary" @onclick="@(() => ChangeIndicatorStatusAsync(indicator, StrategicIndicatorStatus.Achieved))">تحقيق</button><button class="secondary" @onclick="@(() => ChangeIndicatorStatusAsync(indicator, StrategicIndicatorStatus.AtRisk))">متعثر</button></td></tr>
            }
        </tbody>
    </table>
</section>

<section class="table-section" style="margin-top:14px">
    <div class="table-title"><span><i class="fa-solid fa-sliders"></i> متغيرات الخطة</span></div>
    <table>
        <thead><tr><th>الخطة</th><th>المتغير</th><th>القيمة</th><th>المصدر</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var variable in variables)
            {
                <tr><td>@variable.PlanTitle</td><td>@variable.Name</td><td>@variable.Value</td><td>@variable.Source / @(variable.IsAutomated ? "مؤتمت" : "يدوي")</td><td><button class="secondary" @onclick="@(() => EditVariable(variable))">تعديل</button></td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<StrategicPlanResponse> plans = [];
    private List<StrategicPerspectiveResponse> perspectives = [];
    private List<StrategicGoalResponse> goals = [];
    private List<StrategicIndicatorResponse> indicators = [];
    private List<StrategicVariableResponse> variables = [];
    private int? editingPlanId;
    private string planTitle = string.Empty;
    private DateTime startDate = DateTime.UtcNow.AddHours(3).Date;
    private DateTime endDate = DateTime.UtcNow.AddHours(3).Date.AddYears(3);
    private ExcellenceRecordStatus planStatus = ExcellenceRecordStatus.Active;
    private string? vision;
    private string? mission;
    private string? planNotes;
    private int? editingPerspectiveId;
    private int perspectivePlanId;
    private string perspectiveName = string.Empty;
    private int perspectiveSortOrder = 1;
    private int? editingGoalId;
    private int goalPerspectiveId;
    private string goalTitle = string.Empty;
    private string? goalDescription;
    private int goalSortOrder = 1;
    private string? visionAlignment;
    private string? sustainabilityAlignment;
    private int? editingIndicatorId;
    private int indicatorPlanId;
    private int? indicatorGoalId;
    private int? parentIndicatorId;
    private StrategicIndicatorKind indicatorKind = StrategicIndicatorKind.Main;
    private string indicatorName = string.Empty;
    private decimal indicatorTarget = 100;
    private decimal indicatorActual;
    private string indicatorUnit = "%";
    private string? indicatorOwner;
    private string? relatedProject;
    private string? relatedProgram;
    private StrategicIndicatorStatus indicatorStatus = StrategicIndicatorStatus.Active;
    private string? indicatorNotes;
    private int? editingVariableId;
    private string variableName = string.Empty;
    private decimal variableValue;
    private bool isAutomated = true;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        plans = await Excellence.GetStrategicPlansAsync();
        perspectives = await Excellence.GetStrategicPerspectivesAsync();
        goals = await Excellence.GetStrategicGoalsAsync();
        indicators = await Excellence.GetStrategicIndicatorsAsync();
        variables = await Excellence.GetStrategicVariablesAsync();
    }

    private async Task SavePlanAsync()
    {
        var result = await Excellence.SaveStrategicPlanAsync(editingPlanId, new SaveStrategicPlanRequest(planTitle, startDate, endDate, planStatus, vision, mission, planNotes));
        success = result.Success;
        message = result.Message;
        if (result.Success)
            ResetPlan();
        await LoadAsync();
    }

    private async Task SavePerspectiveAsync()
    {
        var result = await Excellence.SaveStrategicPerspectiveAsync(editingPerspectiveId, new SaveStrategicPerspectiveRequest(perspectivePlanId, perspectiveName, perspectiveSortOrder));
        success = result.Success;
        message = result.Message;
        if (result.Success)
            ResetPerspective();
        await LoadAsync();
    }

    private async Task SaveGoalAsync()
    {
        var result = await Excellence.SaveStrategicGoalAsync(editingGoalId, new SaveStrategicGoalRequest(goalPerspectiveId, goalTitle, goalDescription, visionAlignment, sustainabilityAlignment, goalSortOrder));
        success = result.Success;
        message = result.Message;
        if (result.Success)
            ResetGoal();
        await LoadAsync();
    }

    private async Task SaveIndicatorAsync()
    {
        var result = await Excellence.SaveStrategicIndicatorAsync(editingIndicatorId, new SaveStrategicIndicatorRequest(indicatorPlanId, indicatorGoalId, parentIndicatorId, indicatorKind, indicatorName, indicatorTarget, indicatorActual, indicatorUnit, indicatorOwner, relatedProject, relatedProgram, indicatorStatus, indicatorNotes));
        success = result.Success;
        message = result.Message;
        if (result.Success)
            ResetIndicator();
        await LoadAsync();
    }

    private async Task SaveVariableAsync()
    {
        var result = await Excellence.SaveStrategicVariableAsync(editingVariableId, new SaveStrategicVariableRequest(indicatorPlanId, variableName, variableValue, "Manual", isAutomated));
        success = result.Success;
        message = result.Message;
        if (result.Success)
            ResetVariable();
        await LoadAsync();
    }

    private async Task FetchVariablesAsync()
    {
        var plan = plans.FirstOrDefault();
        if (plan is null) { success = false; message = "لا توجد خطة لتحديث المتغيرات."; return; }
        await Excellence.FetchAutomatedStrategicVariablesAsync(plan.Id);
        success = true;
        message = "تم تحديث قيم التحقق المؤتمتة.";
        await LoadAsync();
    }

    private async Task ApplyVariablesAsync()
    {
        var planId = indicatorPlanId > 0 ? indicatorPlanId : plans.FirstOrDefault()?.Id ?? 0;
        if (planId <= 0) { success = false; message = "لا توجد خطة لتطبيق المتغيرات."; return; }
        var result = await Excellence.ApplyStrategicVariablesAsync(planId, new ApplyStrategicVariablesRequest(true, "تحديث من متغيرات الخطة"));
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void EditPlan(StrategicPlanResponse plan)
    {
        editingPlanId = plan.Id;
        planTitle = plan.Title;
        startDate = plan.StartDate;
        endDate = plan.EndDate;
        planStatus = Enum.TryParse<ExcellenceRecordStatus>(plan.Status, out var parsedStatus) ? parsedStatus : ExcellenceRecordStatus.Active;
        vision = plan.Vision;
        mission = plan.Mission;
        planNotes = plan.Notes;
        perspectivePlanId = plan.Id;
        indicatorPlanId = plan.Id;
        message = null;
    }

    private async Task ChangePlanStatusAsync(StrategicPlanResponse plan, ExcellenceRecordStatus status)
    {
        var result = await Excellence.SaveStrategicPlanAsync(plan.Id, new SaveStrategicPlanRequest(plan.Title, plan.StartDate, plan.EndDate, status, plan.Vision, plan.Mission, plan.Notes));
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void EditPerspective(StrategicPerspectiveResponse perspective)
    {
        editingPerspectiveId = perspective.Id;
        perspectivePlanId = perspective.StrategicPlanId;
        perspectiveName = perspective.Name;
        perspectiveSortOrder = perspective.SortOrder;
        goalPerspectiveId = perspective.Id;
        message = null;
    }

    private void EditGoal(StrategicGoalResponse goal)
    {
        editingGoalId = goal.Id;
        goalPerspectiveId = goal.StrategicPerspectiveId;
        goalTitle = goal.Title;
        goalDescription = goal.Description;
        visionAlignment = goal.Vision2030Alignment;
        sustainabilityAlignment = goal.SustainabilityAlignment;
        goalSortOrder = goal.SortOrder;
        indicatorGoalId = goal.Id;
        message = null;
    }

    private void EditIndicator(StrategicIndicatorResponse indicator)
    {
        editingIndicatorId = indicator.Id;
        indicatorPlanId = indicator.StrategicPlanId;
        indicatorGoalId = indicator.StrategicGoalId;
        parentIndicatorId = indicator.ParentIndicatorId;
        indicatorKind = Enum.TryParse<StrategicIndicatorKind>(indicator.Kind, out var parsedKind) ? parsedKind : StrategicIndicatorKind.Main;
        indicatorName = indicator.Name;
        indicatorTarget = indicator.TargetValue;
        indicatorActual = indicator.ActualValue;
        indicatorUnit = indicator.Unit;
        indicatorOwner = indicator.OwnerName;
        relatedProject = indicator.RelatedProjectName;
        relatedProgram = indicator.RelatedProgramName;
        indicatorStatus = Enum.TryParse<StrategicIndicatorStatus>(indicator.Status, out var parsedStatus) ? parsedStatus : StrategicIndicatorStatus.Active;
        indicatorNotes = indicator.Notes;
        message = null;
    }

    private async Task ChangeIndicatorStatusAsync(StrategicIndicatorResponse indicator, StrategicIndicatorStatus status)
    {
        var result = await Excellence.SaveStrategicIndicatorAsync(indicator.Id, new SaveStrategicIndicatorRequest(indicator.StrategicPlanId, indicator.StrategicGoalId, indicator.ParentIndicatorId, Enum.TryParse<StrategicIndicatorKind>(indicator.Kind, out var parsedKind) ? parsedKind : StrategicIndicatorKind.Main, indicator.Name, indicator.TargetValue, indicator.ActualValue, indicator.Unit, indicator.OwnerName, indicator.RelatedProjectName, indicator.RelatedProgramName, status, indicator.Notes));
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void EditVariable(StrategicVariableResponse variable)
    {
        editingVariableId = variable.Id;
        indicatorPlanId = variable.StrategicPlanId;
        variableName = variable.Name;
        variableValue = variable.Value;
        isAutomated = variable.IsAutomated;
        message = null;
    }

    private void ResetPlan()
    {
        editingPlanId = null;
        planTitle = string.Empty;
        startDate = DateTime.UtcNow.AddHours(3).Date;
        endDate = DateTime.UtcNow.AddHours(3).Date.AddYears(3);
        planStatus = ExcellenceRecordStatus.Active;
        vision = null;
        mission = null;
        planNotes = null;
    }

    private void ResetPerspectiveGoal()
    {
        ResetPerspective();
        ResetGoal();
    }

    private void ResetPerspective()
    {
        editingPerspectiveId = null;
        perspectivePlanId = 0;
        perspectiveName = string.Empty;
        perspectiveSortOrder = 1;
    }

    private void ResetGoal()
    {
        editingGoalId = null;
        goalPerspectiveId = 0;
        goalTitle = string.Empty;
        goalDescription = null;
        goalSortOrder = 1;
        visionAlignment = null;
        sustainabilityAlignment = null;
    }

    private void ResetIndicatorVariable()
    {
        ResetIndicator();
        ResetVariable();
    }

    private void ResetIndicator()
    {
        editingIndicatorId = null;
        indicatorPlanId = 0;
        indicatorGoalId = null;
        parentIndicatorId = null;
        indicatorKind = StrategicIndicatorKind.Main;
        indicatorName = string.Empty;
        indicatorTarget = 100;
        indicatorActual = 0;
        indicatorUnit = "%";
        indicatorOwner = null;
        relatedProject = null;
        relatedProgram = null;
        indicatorStatus = StrategicIndicatorStatus.Active;
        indicatorNotes = null;
    }

    private void ResetVariable()
    {
        editingVariableId = null;
        variableName = string.Empty;
        variableValue = 0;
        isAutomated = true;
    }
}
