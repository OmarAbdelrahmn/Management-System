@page "/tech-enablement/visual-assets"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject TechEnablementUiService Tech

<h1 class="page-title">إدارة التصميمات البصرية</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-palette"></i><div><h2>قالب بصري</h2><p>ثيم لوحة التحكم، قوالب المطبوعات، كروت الإهداء، المعايدات، المستندات، وشهادات التبرع.</p></div></div>
    <div class="form-grid compact">
        <label>الاسم<input @bind="name" /></label>
        <label>النوع<select @bind="assetType"><option value="@VisualAssetType.DashboardTheme">ثيم لوحة التحكم</option><option value="@VisualAssetType.PrintTemplate">مطبوعات</option><option value="@VisualAssetType.GiftCard">كرت إهداء</option><option value="@VisualAssetType.Greeting">معايدة</option><option value="@VisualAssetType.PdfDocument">مستند PDF</option><option value="@VisualAssetType.Certificate">شهادة</option></select></label>
        <label>رابط الملف<input @bind="fileUrl" /></label>
        <label>نشط<input type="checkbox" @bind="isActive" /></label>
        <label class="span-2">تصميم JSON<input @bind="designJson" /></label>
        <label class="span-2">ملاحظات<input @bind="notes" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveAsync">حفظ القالب</button><button class="secondary" @onclick="LoadCertificatesAsync">الشهادات</button><button class="secondary" @onclick="LoadActiveAsync">النشطة</button><button class="secondary" @onclick="LoadAsync">كل القوالب</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-database"></i> قوالب التصميمات</span></div>
    <table>
        <thead><tr><th>الاسم</th><th>النوع</th><th>الملف</th><th>نشط</th><th>ملاحظات</th></tr></thead>
        <tbody>
            @foreach (var item in assets)
            {
                <tr><td>@item.Name</td><td>@item.AssetType</td><td>@item.FileUrl<br />@item.DesignJson</td><td>@(item.IsActive ? "نعم" : "لا")</td><td>@item.Notes</td></tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<VisualAssetTemplateResponse> assets = [];
    private string name = string.Empty;
    private VisualAssetType assetType = VisualAssetType.PrintTemplate;
    private string? fileUrl;
    private string? designJson;
    private bool isActive = true;
    private string? notes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync() => assets = await Tech.GetVisualAssetsAsync();
    private async Task LoadActiveAsync() => assets = await Tech.GetVisualAssetsAsync(isActive: true);
    private async Task LoadCertificatesAsync() => assets = await Tech.GetVisualAssetsAsync(VisualAssetType.Certificate);
    private async Task SaveAsync(){ var result = await Tech.SaveVisualAssetAsync(null, new SaveVisualAssetTemplateRequest(name, assetType, fileUrl, designJson, isActive, notes)); success = result.Success; message = result.Message; await LoadAsync(); }
}
