@page "/programs-projects/suppliers"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject ProgramsProjectsUiService ProgramsProjects

<h1 class="page-title">إدارة الموردين</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading"><i class="fa-solid fa-truck-field"></i><div><h2>حساب مورد</h2><p>إنشاء وتحديث موردين البرامج والمشاريع.</p></div></div>
    <div class="form-grid compact">
        <label>اسم المورد<input @bind="name" /></label>
        <label>مسؤول التواصل<input @bind="contactPerson" /></label>
        <label>الجوال<input @bind="mobile" /></label>
        <label>البريد<input type="email" @bind="email" /></label>
        <label>المدينة<input @bind="city" /></label>
        <label>الحالة<select @bind="status"><option value="@ProgramSupplierStatus.Active">نشط</option><option value="@ProgramSupplierStatus.Inactive">غير نشط</option><option value="@ProgramSupplierStatus.Archived">مؤرشف</option></select></label>
        <label class="span-2">ملاحظات<input @bind="notes" /></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveAsync">حفظ المورد</button><button class="secondary" @onclick="ResetForm">تفريغ</button></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-magnifying-glass"></i><div><h2>بحث الموردين</h2><p>قاعدة بيانات الموردين مع الحذف والاستعادة كحالة أرشفة.</p></div></div>
    <div class="form-grid compact">
        <label>بحث<input @bind="search" /></label>
        <label>الحالة<select @bind="statusText"><option value="">الكل</option><option value="Active">نشط</option><option value="Inactive">غير نشط</option><option value="Archived">مؤرشف</option></select></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="LoadAsync">بحث</button></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-file-invoice-dollar"></i><div><h2>عروض الموردين</h2><p>تسجيل عروض الأسعار واعتمادها وتحويل العرض المعتمد إلى عقد مشروع.</p></div></div>
    <div class="form-grid">
        <label>المشروع<select @bind="proposalProjectId">@foreach (var project in projects){<option value="@project.Id">@project.Name</option>}</select></label>
        <label>المورد<select @bind="proposalSupplierId">@foreach (var supplier in suppliers){<option value="@supplier.Id">@supplier.Name</option>}</select></label>
        <label>رقم العرض<input @bind="proposalNumber" placeholder="يولد تلقائياً عند تركه فارغاً" /></label>
        <label>الحالة<select @bind="proposalStatus"><option value="@ProgramSupplierProposalStatus.Draft">مسودة</option><option value="@ProgramSupplierProposalStatus.Submitted">مقدم</option><option value="@ProgramSupplierProposalStatus.UnderReview">قيد المراجعة</option><option value="@ProgramSupplierProposalStatus.Approved">معتمد</option><option value="@ProgramSupplierProposalStatus.Rejected">مرفوض</option><option value="@ProgramSupplierProposalStatus.Cancelled">ملغي</option></select></label>
        <label class="span-2">عنوان العرض<input @bind="proposalTitle" /></label>
        <label>القيمة<input type="number" step="0.01" @bind="proposalAmount" /></label>
        <label>تاريخ التقديم<input type="date" @bind="proposalSubmittedAt" /></label>
        <label>صالح حتى<input type="date" @bind="proposalValidUntil" /></label>
        <label class="span-2">نطاق العمل<textarea @bind="proposalScope"></textarea></label>
        <label class="span-2">ملاحظات<input @bind="proposalNotes" /></label>
        <label class="span-2">ملاحظات القرار<textarea @bind="proposalDecisionNotes"></textarea></label>
    </div>
    <div class="actions-row"><button class="primary" @onclick="SaveProposalAsync">حفظ العرض</button><button class="secondary" @onclick="ResetProposalForm">تفريغ العرض</button></div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-money-bill-transfer"></i><div><h2>سداد عقود الموردين</h2><p>تسجيل مصروف مرتبط برقم العقد مع منع السداد الزائد عن قيمة العقد.</p></div></div>
    <div class="form-grid compact">
        <label>مبلغ السداد<input type="number" step="0.01" @bind="contractPaymentAmount" placeholder="اتركه 0 لسداد كامل العقد" /></label>
        <label>تاريخ السداد<input type="date" @bind="contractPaymentPaidAt" /></label>
        <label>مرجع السداد<input @bind="contractPaymentReference" /></label>
        <label class="span-2">ملاحظات<input @bind="contractPaymentNotes" /></label>
    </div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-database"></i> قاعدة بيانات الموردين</span></div>
    <table>
        <thead><tr><th>المورد</th><th>التواصل</th><th>المدينة</th><th>الحالة</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var supplier in suppliers)
            {
                <tr>
                    <td>@supplier.Name</td>
                    <td>@supplier.ContactPerson<br />@supplier.Mobile<br />@supplier.Email</td>
                    <td>@supplier.City</td>
                    <td><span class="status">@supplier.Status</span></td>
                    <td>
                        <button class="secondary" @onclick="@(() => Edit(supplier))">تعديل</button>
                        <button class="secondary" @onclick="@(() => ChangeStatusAsync(supplier, ProgramSupplierStatus.Archived))">حذف</button>
                        <button class="secondary" @onclick="@(() => ChangeStatusAsync(supplier, ProgramSupplierStatus.Active))">استعادة</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="table-section" style="margin-top:14px">
    <div class="table-title"><span><i class="fa-solid fa-file-contract"></i> عروض الموردين</span></div>
    <table>
        <thead><tr><th>العرض</th><th>المشروع</th><th>المورد</th><th>القيمة</th><th>الصلاحية</th><th>الحالة</th><th>العقد</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var proposal in proposals)
            {
                <tr>
                    <td>@proposal.ProposalNumber<br />@proposal.Title</td>
                    <td>@proposal.ProjectName</td>
                    <td>@proposal.SupplierName</td>
                    <td>@proposal.Amount</td>
                    <td>@proposal.ValidUntil?.ToString("yyyy-MM-dd")</td>
                    <td><span class="status">@proposal.Status</span></td>
                    <td>@proposal.ConvertedContractNumber</td>
                    <td>
                        <button class="secondary" @onclick="@(() => EditProposal(proposal))">تعديل</button>
                        @if (CanDecideProposal(proposal, ProgramSupplierProposalStatus.UnderReview))
                        {
                            <button class="secondary" @onclick="@(() => DecideProposalAsync(proposal.Id, ProgramSupplierProposalStatus.UnderReview))">مراجعة</button>
                        }
                        @if (CanDecideProposal(proposal, ProgramSupplierProposalStatus.Approved))
                        {
                            <button class="secondary" @onclick="@(() => DecideProposalAsync(proposal.Id, ProgramSupplierProposalStatus.Approved))">اعتماد</button>
                        }
                        @if (CanDecideProposal(proposal, ProgramSupplierProposalStatus.Rejected))
                        {
                            <button class="secondary" @onclick="@(() => DecideProposalAsync(proposal.Id, ProgramSupplierProposalStatus.Rejected))">رفض</button>
                        }
                        @if (CanDecideProposal(proposal, ProgramSupplierProposalStatus.Cancelled))
                        {
                            <button class="secondary" @onclick="@(() => DecideProposalAsync(proposal.Id, ProgramSupplierProposalStatus.Cancelled))">إلغاء</button>
                        }
                        @if (proposal.Status == ProgramSupplierProposalStatus.Approved.ToString())
                        {
                            <button class="secondary" @onclick="@(() => ConvertProposalAsync(proposal.Id))">تحويل لعقد</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="table-section" style="margin-top:14px">
    <div class="table-title"><span><i class="fa-solid fa-file-signature"></i> عقود الموردين</span></div>
    <table>
        <thead><tr><th>العقد</th><th>المشروع</th><th>المورد</th><th>القيمة</th><th>التوقيع</th><th>إجراء</th></tr></thead>
        <tbody>
            @foreach (var contract in contracts)
            {
                <tr>
                    <td>@contract.ContractNumber<br />@contract.Title</td>
                    <td>@contract.ProjectName</td>
                    <td>@contract.SupplierName</td>
                    <td>@contract.Amount</td>
                    <td>@contract.SignedAt.ToString("yyyy-MM-dd")</td>
                    <td><button class="secondary" @onclick="@(() => PayContractAsync(contract))">تسجيل سداد</button></td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private List<ProgramSupplierResponse> suppliers = [];
    private List<ProgramProjectResponse> projects = [];
    private List<ProgramSupplierProposalResponse> proposals = [];
    private List<ProgramProjectContractResponse> contracts = [];
    private int? editingId;
    private string name = string.Empty;
    private string? contactPerson;
    private string? mobile;
    private string? email;
    private string? city;
    private ProgramSupplierStatus status = ProgramSupplierStatus.Active;
    private string? notes;
    private string? search;
    private string statusText = string.Empty;
    private int? editingProposalId;
    private int proposalProjectId;
    private int proposalSupplierId;
    private string? proposalNumber;
    private string proposalTitle = string.Empty;
    private string? proposalScope;
    private decimal proposalAmount;
    private DateTime proposalSubmittedAt = DateTime.UtcNow.AddHours(3).Date;
    private DateTime? proposalValidUntil;
    private ProgramSupplierProposalStatus proposalStatus = ProgramSupplierProposalStatus.Submitted;
    private string? proposalNotes;
    private string? proposalDecisionNotes;
    private decimal contractPaymentAmount;
    private DateTime contractPaymentPaidAt = DateTime.UtcNow.AddHours(3).Date;
    private string? contractPaymentReference;
    private string? contractPaymentNotes;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        projects = await ProgramsProjects.SearchProjectsAsync();
        await LoadAsync();
        proposalProjectId = projects.FirstOrDefault()?.Id ?? 0;
        proposalSupplierId = suppliers.FirstOrDefault()?.Id ?? 0;
    }

    private async Task LoadAsync()
    {
        var parsedStatus = Enum.TryParse<ProgramSupplierStatus>(statusText, out var value) ? value : (ProgramSupplierStatus?)null;
        suppliers = await ProgramsProjects.GetSuppliersAsync(search, parsedStatus);
        proposals = await ProgramsProjects.GetSupplierProposalsAsync();
        contracts = await ProgramsProjects.GetContractsAsync();
        if (proposalSupplierId == 0)
            proposalSupplierId = suppliers.FirstOrDefault()?.Id ?? 0;
    }

    private async Task SaveAsync()
    {
        var result = await ProgramsProjects.SaveSupplierAsync(editingId, new SaveProgramSupplierRequest(name, contactPerson, mobile, email, city, status, notes));
        success = result.Success;
        message = result.Message;
        if (success)
            ResetForm();
        await LoadAsync();
    }

    private async Task ChangeStatusAsync(ProgramSupplierResponse supplier, ProgramSupplierStatus newStatus)
    {
        var result = await ProgramsProjects.SaveSupplierAsync(supplier.Id, new SaveProgramSupplierRequest(supplier.Name, supplier.ContactPerson, supplier.Mobile, supplier.Email, supplier.City, newStatus, supplier.Notes));
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private async Task SaveProposalAsync()
    {
        var result = await ProgramsProjects.SaveSupplierProposalAsync(editingProposalId, new SaveProgramSupplierProposalRequest(proposalProjectId, proposalSupplierId, proposalNumber, proposalTitle, proposalScope, proposalAmount, proposalSubmittedAt, proposalValidUntil, proposalStatus, proposalNotes));
        success = result.Success;
        message = result.Message;
        if (success)
            ResetProposalForm();
        await LoadAsync();
    }

    private async Task DecideProposalAsync(int id, ProgramSupplierProposalStatus newStatus)
    {
        var result = await ProgramsProjects.DecideSupplierProposalAsync(id, newStatus, proposalDecisionNotes);
        success = result.Success;
        message = result.Message;
        if (success)
            proposalDecisionNotes = null;
        await LoadAsync();
    }

    private async Task ConvertProposalAsync(int id)
    {
        var result = await ProgramsProjects.ConvertSupplierProposalToContractAsync(id, new ConvertProgramSupplierProposalRequest(null, DateTime.UtcNow.AddHours(3), null, "تحويل عرض مورد معتمد"));
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private async Task PayContractAsync(ProgramProjectContractResponse contract)
    {
        var amount = contractPaymentAmount > 0 ? contractPaymentAmount : contract.Amount;
        var result = await ProgramsProjects.RecordContractPaymentAsync(contract.Id, new RecordProgramContractPaymentRequest(amount, contractPaymentPaidAt, contractPaymentReference, contractPaymentNotes));
        success = result.Success;
        message = result.Message;
        if (success)
        {
            contractPaymentAmount = 0;
            contractPaymentReference = null;
            contractPaymentNotes = null;
            contractPaymentPaidAt = DateTime.UtcNow.AddHours(3).Date;
        }
        await LoadAsync();
    }

    private void Edit(ProgramSupplierResponse supplier)
    {
        editingId = supplier.Id;
        name = supplier.Name;
        contactPerson = supplier.ContactPerson;
        mobile = supplier.Mobile;
        email = supplier.Email;
        city = supplier.City;
        status = Enum.TryParse<ProgramSupplierStatus>(supplier.Status, out var value) ? value : ProgramSupplierStatus.Active;
        notes = supplier.Notes;
    }

    private void EditProposal(ProgramSupplierProposalResponse proposal)
    {
        editingProposalId = proposal.Id;
        proposalProjectId = proposal.ProgramProjectId;
        proposalSupplierId = proposal.ProgramSupplierId;
        proposalNumber = proposal.ProposalNumber;
        proposalTitle = proposal.Title;
        proposalScope = proposal.Scope;
        proposalAmount = proposal.Amount;
        proposalSubmittedAt = proposal.SubmittedAt.Date;
        proposalValidUntil = proposal.ValidUntil;
        proposalStatus = Enum.TryParse<ProgramSupplierProposalStatus>(proposal.Status, out var value) ? value : ProgramSupplierProposalStatus.Submitted;
        proposalNotes = proposal.Notes;
        proposalDecisionNotes = proposal.DecisionNotes;
    }

    private void ResetForm()
    {
        editingId = null;
        name = string.Empty;
        contactPerson = null;
        mobile = null;
        email = null;
        city = null;
        status = ProgramSupplierStatus.Active;
        notes = null;
    }

    private void ResetProposalForm()
    {
        editingProposalId = null;
        proposalNumber = null;
        proposalTitle = string.Empty;
        proposalScope = null;
        proposalAmount = 0;
        proposalSubmittedAt = DateTime.UtcNow.AddHours(3).Date;
        proposalValidUntil = null;
        proposalStatus = ProgramSupplierProposalStatus.Submitted;
        proposalNotes = null;
        proposalDecisionNotes = null;
    }

    private static bool CanDecideProposal(ProgramSupplierProposalResponse proposal, ProgramSupplierProposalStatus nextStatus)
    {
        var status = proposal.Status;
        return nextStatus switch
        {
            ProgramSupplierProposalStatus.UnderReview =>
                status == ProgramSupplierProposalStatus.Draft.ToString() ||
                status == ProgramSupplierProposalStatus.Submitted.ToString(),
            ProgramSupplierProposalStatus.Approved =>
                status == ProgramSupplierProposalStatus.Submitted.ToString() ||
                status == ProgramSupplierProposalStatus.UnderReview.ToString(),
            ProgramSupplierProposalStatus.Rejected =>
                status == ProgramSupplierProposalStatus.Draft.ToString() ||
                status == ProgramSupplierProposalStatus.Submitted.ToString() ||
                status == ProgramSupplierProposalStatus.UnderReview.ToString(),
            ProgramSupplierProposalStatus.Cancelled =>
                status == ProgramSupplierProposalStatus.Draft.ToString() ||
                status == ProgramSupplierProposalStatus.Submitted.ToString() ||
                status == ProgramSupplierProposalStatus.UnderReview.ToString() ||
                status == ProgramSupplierProposalStatus.Approved.ToString(),
            _ => false
        };
    }
}
