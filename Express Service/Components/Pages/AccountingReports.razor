@page "/accounting/reports"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject AccountingUiService Accounting

<h1 class="page-title">التقارير المحاسبية والموازنة</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading">
        <i class="fa-solid fa-chart-pie"></i>
        <div>
            <h2>@(editingBudgetId.HasValue ? "تعديل موازنة" : "إضافة موازنة")</h2>
            <p>عرض التقارير العامة وإدخال الموازنة والانحراف مع حالات المسودة والاعتماد والإقفال.</p>
        </div>
    </div>
    <div class="form-grid compact">
        <label>السنة<input type="number" @bind="fiscalYear" /></label>
        <label>اسم الموازنة<input @bind="budgetName" /></label>
        <label>الإيرادات المخططة<input type="number" step="0.01" @bind="plannedIncome" /></label>
        <label>المصروفات المخططة<input type="number" step="0.01" @bind="plannedExpenses" /></label>
        <label>
            الحالة
            <select @bind="budgetStatus">
                <option value="@BudgetStatus.Draft">مسودة</option>
                <option value="@BudgetStatus.Approved">معتمدة</option>
                <option value="@BudgetStatus.Closed">مقفلة</option>
            </select>
        </label>
    </div>
    <div class="actions-row">
        <button class="primary" @onclick="SaveBudgetAsync">@(editingBudgetId.HasValue ? "تحديث الموازنة" : "حفظ الموازنة")</button>
        @if (editingBudgetId.HasValue)
        {
            <button class="secondary" @onclick="ResetBudgetForm">إلغاء التعديل</button>
        }
        <button class="secondary" @onclick="LoadAsync">تحديث</button>
    </div>
</section>

<section class="panel" style="margin-top:14px">
    <div class="panel-heading"><i class="fa-solid fa-building-columns"></i><div><h2>المطابقة البنكية</h2><p>سجل رصيد كشف البنك مقابل الرصيد الدفتري واعتماد المطابقة.</p></div></div>
    <div class="form-grid compact"><label>الحساب البنكي<select @bind="reconciliationBankId">@foreach(var bank in banks){<option value="@bank.Id">@bank.BankName - @bank.AccountName</option>}</select></label><label>التاريخ<input type="date" @bind="reconciliationDate" /></label><label>رصيد الكشف<input type="number" step="0.01" @bind="statementBalance" /></label><label>الرصيد الدفتري<input type="number" step="0.01" @bind="bookBalance" /></label><label>الحالة<input value="قيد المراجعة" disabled /></label></div>
    <label style="margin-top:10px">ملاحظات<input @bind="reconciliationNotes" /></label><div class="actions-row"><button class="primary" @onclick="SaveReconciliationAsync">حفظ المطابقة</button></div>
    <div class="table-section" style="margin:14px 0 0"><table><thead><tr><th>البنك</th><th>التاريخ</th><th>الكشف</th><th>الدفتري</th><th>الفرق</th><th>الحالة</th><th>إجراء</th></tr></thead><tbody>@foreach(var item in reconciliations){<tr><td>@item.BankName - @item.AccountName</td><td>@item.ReconciliationDate.ToString("yyyy-MM-dd")</td><td>@item.StatementBalance</td><td>@item.BookBalance</td><td>@item.Difference</td><td><span class="status @(item.IsApproved ? "ok" : "warn")">@(item.IsApproved ? "معتمدة" : "قيد المراجعة")</span></td><td>@if (!item.IsApproved){<button class="primary small" @onclick="() => ApproveReconciliationAsync(item.Id)">اعتماد</button>}</td></tr>}</tbody></table></div>
</section>

<section class="circle-tiles" style="margin-top:14px">
    <article class="circle-tile-content"><span class="circle-icon bg-blue"><i class="fa-solid fa-receipt"></i></span><span>الإيرادات</span><strong class="tile-number">@(dashboard?.PostedIncome ?? 0)</strong><span class="tile-footer">فعلي</span></article>
    <article class="circle-tile-content"><span class="circle-icon bg-orange"><i class="fa-solid fa-money-bill"></i></span><span>المصروفات</span><strong class="tile-number">@(dashboard?.PostedExpenses ?? 0)</strong><span class="tile-footer">فعلي</span></article>
    <article class="circle-tile-content"><span class="circle-icon bg-purple"><i class="fa-solid fa-chart-line"></i></span><span>الانحراف</span><strong class="tile-number">@(dashboard?.BudgetDeviation ?? 0)</strong><span class="tile-footer">موازنة</span></article>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-table"></i> الموازنات</span></div>
    <table>
        <thead>
            <tr>
                <th>السنة</th>
                <th>الاسم</th>
                <th>المخطط</th>
                <th>الفعلي</th>
                <th>الانحراف</th>
                <th>الحالة</th>
                <th>إجراء</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var budget in budgets)
            {
                <tr>
                    <td>@budget.FiscalYear</td>
                    <td>@budget.Name</td>
                    <td>@budget.PlannedIncome / @budget.PlannedExpenses</td>
                    <td>@budget.ActualIncome / @budget.ActualExpenses</td>
                    <td>@budget.Deviation</td>
                    <td>@budget.Status</td>
                    <td>
                        <button class="secondary" @onclick="@(() => EditBudget(budget))">تعديل</button>
                        <button class="secondary" @onclick="@(() => ChangeBudgetStatusAsync(budget, BudgetStatus.Approved))">اعتماد</button>
                        <button class="secondary" @onclick="@(() => ChangeBudgetStatusAsync(budget, BudgetStatus.Closed))">إقفال</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private AccountingDashboardResponse? dashboard;
    private List<FinanceBudgetResponse> budgets = [];
    private List<FinanceBankAccountResponse> banks = [];
    private List<BankReconciliationResponse> reconciliations = [];
    private int? editingBudgetId;
    private int fiscalYear = DateTime.UtcNow.AddHours(3).Year;
    private string budgetName = "الموازنة السنوية";
    private decimal plannedIncome;
    private decimal plannedExpenses;
    private BudgetStatus budgetStatus = BudgetStatus.Draft;
    private bool success;
    private string? message;
    private int reconciliationBankId;
    private DateTime reconciliationDate = DateTime.UtcNow.AddHours(3).Date;
    private decimal statementBalance, bookBalance;
    private string? reconciliationNotes;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        dashboard = await Accounting.GetDashboardAsync();
        budgets = await Accounting.GetBudgetsAsync();
        banks = await Accounting.GetBankAccountsAsync();
        reconciliations = await Accounting.GetBankReconciliationsAsync();
        if (reconciliationBankId == 0) reconciliationBankId = banks.FirstOrDefault()?.Id ?? 0;
    }

    private async Task SaveBudgetAsync()
    {
        var result = await Accounting.SaveBudgetAsync(
            editingBudgetId,
            new SaveFinanceBudgetRequest(fiscalYear, budgetName, plannedIncome, plannedExpenses, budgetStatus));

        success = result.Success;
        message = result.Message;

        if (result.Success)
        {
            ResetBudgetForm();
        }

        await LoadAsync();
    }

    private void EditBudget(FinanceBudgetResponse budget)
    {
        editingBudgetId = budget.Id;
        fiscalYear = budget.FiscalYear;
        budgetName = budget.Name;
        plannedIncome = budget.PlannedIncome;
        plannedExpenses = budget.PlannedExpenses;
        budgetStatus = Enum.TryParse<BudgetStatus>(budget.Status, out var parsedStatus) ? parsedStatus : BudgetStatus.Draft;
        message = null;
    }

    private async Task ChangeBudgetStatusAsync(FinanceBudgetResponse budget, BudgetStatus status)
    {
        var result = await Accounting.SaveBudgetAsync(
            budget.Id,
            new SaveFinanceBudgetRequest(budget.FiscalYear, budget.Name, budget.PlannedIncome, budget.PlannedExpenses, status));

        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void ResetBudgetForm()
    {
        editingBudgetId = null;
        fiscalYear = DateTime.UtcNow.AddHours(3).Year;
        budgetName = "الموازنة السنوية";
        plannedIncome = 0;
        plannedExpenses = 0;
        budgetStatus = BudgetStatus.Draft;
    }

    private async Task SaveReconciliationAsync()
    {
        var result = await Accounting.SaveBankReconciliationAsync(null, new SaveBankReconciliationRequest(reconciliationBankId, reconciliationDate, statementBalance, bookBalance, false, reconciliationNotes));
        success = result.Success; message = result.Message;
        if (success) { statementBalance = bookBalance = 0; reconciliationNotes = null; }
        await LoadAsync();
    }

    private async Task ApproveReconciliationAsync(int id)
    {
        var result = await Accounting.ApproveBankReconciliationAsync(id, reconciliationNotes);
        success = result.Success; message = result.Message;
        await LoadAsync();
    }
}
