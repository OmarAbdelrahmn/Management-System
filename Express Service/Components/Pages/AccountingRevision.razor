@page "/accounting/revision"
@attribute [Authorize(Roles = "Admin,Secretary,Chairman")]
@rendermode InteractiveServer
@inject AccountingUiService Accounting

<h1 class="page-title">المراجعة المالية والأرشيف</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <section class="panel"><div class="panel-body"><span class="status @(success ? "ok" : "bad")">@message</span></div></section>
}

<section class="panel">
    <div class="panel-heading">
        <i class="fa-solid fa-check-double"></i>
        <div>
            <h2>@(editingReviewId.HasValue ? "تعديل سجل مراجعة" : "إضافة سجل مراجعة")</h2>
            <p>مطابقة مراجعات التبرعات والإيرادات والمصروفات والتسويق مع حالة الاعتماد والأرشفة.</p>
        </div>
    </div>
    <div class="form-grid compact">
        <label>
            نوع المراجعة
            <select @bind="kind">
                <option value="@FinancialReviewKind.IncomeDonation">تبرعات</option>
                <option value="@FinancialReviewKind.Income">إيرادات</option>
                <option value="@FinancialReviewKind.Expense">مصروفات</option>
                <option value="@FinancialReviewKind.MarketingOnline">تسويق إلكتروني</option>
                <option value="@FinancialReviewKind.MarketingBank">بنكي</option>
                <option value="@FinancialReviewKind.MarketingBalance">مطابقة أرصدة التسويق</option>
                <option value="@FinancialReviewKind.MarketingLocation">مواقع التسويق</option>
                <option value="@FinancialReviewKind.MarketingFailed">عمليات تسويق فاشلة</option>
            </select>
        </label>
        <label>المرجع<input @bind="referenceNumber" /></label>
        <label>المبلغ<input type="number" step="0.01" @bind="amount" /></label>
        <label>
            الحالة
            <select @bind="reviewStatus">
                <option value="@AccountingRecordStatus.Draft">مسودة</option>
                <option value="@AccountingRecordStatus.Approved">معتمد</option>
                <option value="@AccountingRecordStatus.Rejected">مرفوض</option>
                <option value="@AccountingRecordStatus.Archived">مؤرشف</option>
            </select>
        </label>
        <label class="wide">ملاحظات القرار<input @bind="decisionNotes" /></label>
    </div>
    <div class="actions-row">
        <button class="primary" @onclick="SaveAsync">@(editingReviewId.HasValue ? "تحديث المراجعة" : "حفظ مراجعة")</button>
        @if (editingReviewId.HasValue)
        {
            <button class="secondary" @onclick="ResetForm">إلغاء التعديل</button>
        }
        <button class="secondary" @onclick="LoadAsync">تحديث القائمة</button>
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <i class="fa-solid fa-filter"></i>
        <div>
            <h2>تصفية السجلات</h2>
            <p>عرض سجلات المراجعة حسب النوع والحالة مثل قوائم النظام التشغيلية.</p>
        </div>
    </div>
    <div class="form-grid compact">
        <label>
            النوع
            <select @bind="filterKindText">
                <option value="">كل الأنواع</option>
                @foreach (var option in Enum.GetValues<FinancialReviewKind>())
                {
                    <option value="@option">@option</option>
                }
            </select>
        </label>
        <label>
            الحالة
            <select @bind="filterStatusText">
                <option value="">كل الحالات</option>
                @foreach (var option in reviewStatuses)
                {
                    <option value="@option">@option</option>
                }
            </select>
        </label>
    </div>
    <div class="actions-row"><button class="secondary" @onclick="LoadAsync">تطبيق التصفية</button></div>
</section>

<section class="table-section">
    <div class="table-title"><span><i class="fa-solid fa-check-double"></i> سجلات المراجعة</span></div>
    <table>
        <thead>
            <tr>
                <th>النوع</th>
                <th>المرجع</th>
                <th>المبلغ</th>
                <th>الحالة</th>
                <th>ملاحظات</th>
                <th>إجراء</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in items)
            {
                <tr>
                    <td>@item.Kind</td>
                    <td>@item.ReferenceNumber</td>
                    <td>@item.Amount</td>
                    <td>@item.Status</td>
                    <td>@item.DecisionNotes</td>
                    <td>
                        <button class="secondary" @onclick="@(() => EditReview(item))">تعديل</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(item.Id, AccountingRecordStatus.Approved))">اعتماد</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(item.Id, AccountingRecordStatus.Rejected))">رفض</button>
                        <button class="secondary" @onclick="@(() => DecideAsync(item.Id, AccountingRecordStatus.Archived))">أرشفة</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private readonly AccountingRecordStatus[] reviewStatuses =
    [
        AccountingRecordStatus.Draft,
        AccountingRecordStatus.Approved,
        AccountingRecordStatus.Rejected,
        AccountingRecordStatus.Archived
    ];

    private List<FinancialReviewItemResponse> items = [];
    private int? editingReviewId;
    private FinancialReviewKind kind = FinancialReviewKind.Income;
    private AccountingRecordStatus reviewStatus = AccountingRecordStatus.Draft;
    private string referenceNumber = string.Empty;
    private decimal amount;
    private string? decisionNotes;
    private string filterKindText = string.Empty;
    private string filterStatusText = string.Empty;
    private bool success;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        FinancialReviewKind? filterKind = Enum.TryParse<FinancialReviewKind>(filterKindText, out var parsedKind) ? parsedKind : null;
        AccountingRecordStatus? filterStatus = Enum.TryParse<AccountingRecordStatus>(filterStatusText, out var parsedStatus) ? parsedStatus : null;
        items = await Accounting.GetReviewItemsAsync(filterKind, filterStatus);
    }

    private async Task SaveAsync()
    {
        var result = await Accounting.SaveReviewItemAsync(
            editingReviewId,
            new SaveFinancialReviewItemRequest(kind, referenceNumber, amount, reviewStatus, decisionNotes));

        success = result.Success;
        message = result.Message;

        if (result.Success)
        {
            ResetForm();
        }

        await LoadAsync();
    }

    private void EditReview(FinancialReviewItemResponse item)
    {
        editingReviewId = item.Id;
        kind = Enum.TryParse<FinancialReviewKind>(item.Kind, out var parsedKind) ? parsedKind : FinancialReviewKind.Income;
        reviewStatus = Enum.TryParse<AccountingRecordStatus>(item.Status, out var parsedStatus) ? parsedStatus : AccountingRecordStatus.Draft;
        referenceNumber = item.ReferenceNumber;
        amount = item.Amount;
        decisionNotes = item.DecisionNotes;
        message = null;
    }

    private async Task DecideAsync(int id, AccountingRecordStatus status)
    {
        var result = await Accounting.DecideReviewItemAsync(id, status, decisionNotes);
        success = result.Success;
        message = result.Message;
        await LoadAsync();
    }

    private void ResetForm()
    {
        editingReviewId = null;
        kind = FinancialReviewKind.Income;
        reviewStatus = AccountingRecordStatus.Draft;
        referenceNumber = string.Empty;
        amount = 0;
        decisionNotes = null;
    }
}
