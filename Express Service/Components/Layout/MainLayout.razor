@inherits LayoutComponentBase
@inject SystemCatalogUiService Catalog

<header id="nav-sticky" class="rafed-header">
    <div class="header-brand">
        <strong>نظام الإدارة الإلكتروني</strong>
        <span>إدارة المجالس والاجتماعات والخدمات</span>
    </div>

    <div class="header-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input id="search_input" placeholder="بحث.." />
    </div>

    <div class="header-actions">
        <a href="/tasks/mine"><i class="fa-solid fa-list-check"></i> المهام</a>
        <button class="has-badge"><i class="fa-solid fa-bell"></i> التنبيهات <span>3</span></button>
        <a href="/swagger"><i class="fa-solid fa-globe"></i> API</a>
        <div class="user-menu">
            <span class="avatar"><i class="fa-solid fa-user"></i></span>
            <AuthorizeView>
                <Authorized>
                    <div>
                        <strong>@context.User.Identity?.Name</strong>
                        <small><a href="/logout">خروج</a></small>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</header>

<aside class="menu-container">
    <div class="logo">
        <div class="logo-card">
            <strong>إدارة</strong>
            <span>نظام الإدارة الموحد</span>
            <small>مطابقة تنقل رافد</small>
        </div>
    </div>

    <nav id="side-menu" class="side-panel">
        @if (navigation.Count == 0)
        {
            <details open>
                <summary><i class="fa-solid fa-layer-group"></i><span>خطة خدمات النظام</span><i class="fa-solid fa-angle-down angle"></i></summary>
                <a href="/system/modules">تجهيز خريطة رافد</a>
            </details>
        }
        else
        {
            @foreach (var module in navigation)
            {
                <details>
                    <summary>
                        <i class="@SidebarIcon(module.IconCss)"></i>
                        <span>@module.NameAr</span>
                        <i class="fa-solid fa-angle-down angle"></i>
                    </summary>
                    @foreach (var group in module.Groups)
                    {
                        <div class="side-separator">@group.NameAr</div>
                        @foreach (var navPage in group.Pages)
                        {
                            <a href="@navPage.Route" title="@navPage.OriginalHref">
                                @navPage.NameAr
                                @if (navPage.Status != "Implemented")
                                {
                                    <small>مخطط</small>
                                }
                            </a>
                        }
                    }
                </details>
            }
        }
    </nav>
</aside>

<main class="page-container-legacy">
    @Body
</main>

@code {
    private List<SystemNavigationModuleResponse> navigation = [];

    protected override async Task OnInitializedAsync()
    {
        navigation = await Catalog.GetNavigationAsync();
    }

    private static string SidebarIcon(string? iconCss)
    {
        if (string.IsNullOrWhiteSpace(iconCss))
            return "fa-solid fa-folder-open";

        return iconCss
            .Replace("menu-icon", string.Empty, StringComparison.OrdinalIgnoreCase)
            .Replace("fal", "fa-solid", StringComparison.OrdinalIgnoreCase)
            .Trim();
    }
}
