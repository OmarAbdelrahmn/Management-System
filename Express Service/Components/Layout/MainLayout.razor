@inherits LayoutComponentBase
@inject SystemCatalogUiService Catalog
@inject MessagingUiService Messaging
@inject NavigationManager Navigation
@inject ILogger<MainLayout> Logger

<header id="nav-sticky" class="rafed-header">
    <div class="header-brand">
        <button class="mobile-menu-toggle" type="button" data-shell-toggle="menu" aria-label="فتح القائمة" aria-controls="side-navigation" aria-expanded="false"><i class="fa-solid fa-bars"></i></button>
        <a class="header-brand-lockup" href="/dashboard" aria-label="الذهاب إلى لوحة التحكم">
            <span class="header-brand-mark"><i class="fa-solid fa-building"></i></span>
            <span class="header-brand-copy">
                <strong>مؤسسة سعيد مبارك الشهراني</strong>
                <span>للتجارة · منصة الخدمات الإدارية</span>
            </span>
        </a>
        <button class="mobile-actions-toggle" type="button" data-shell-toggle="actions" aria-label="فتح قائمة المستخدم" aria-controls="header-actions" aria-expanded="false"><i class="fa-solid fa-circle-user"></i></button>
    </div>

    <div id="header-actions" class="header-actions">
        @if (HasRoute("/tasks/mine") || HasRoute("/tasks/database") || HasRoute("/tasks/create"))
        {
        <details class="header-dropdown">
            <summary><i class="fa-solid fa-list-check"></i> المهام <i class="fa-solid fa-angle-down"></i></summary>
            <div class="header-dropdown-menu">
                @if (HasRoute("/tasks/mine")){<a href="/tasks/mine">مهامي</a>}
                @if (HasRoute("/tasks/database")){<a href="/tasks/database">قاعدة المهام</a>}
                @if (HasRoute("/tasks/create")){<a href="/tasks/create">إضافة مهمة</a>}
            </div>
        </details>
        }
        @if (HasRoute("/notifications/manage") || HasRoute("/notifications/database"))
        {
        <details class="header-dropdown">
            <summary class="has-badge"><i class="fa-solid fa-bell"></i> التنبيهات @if (unreadNotificationCount > 0){<span>@unreadNotificationCount</span>}<i class="fa-solid fa-angle-down"></i></summary>
            <div class="header-dropdown-menu">
                @if (HasRoute("/notifications/manage")){<a href="/notifications/manage">إدارة التنبيهات</a>}
                @if (HasRoute("/notifications/database")){<a href="/notifications/database">قاعدة التنبيهات</a>}
            </div>
        </details>
        }
        <AuthorizeView>
            <Authorized>
                <details class="header-dropdown user-dropdown">
                    <summary class="user-summary" aria-label="قائمة المستخدم">
                        <span class="avatar"><i class="fa-solid fa-user"></i></span>
                        <span class="user-summary-copy">
                            <strong>@context.User.Identity?.Name</strong>
                            <small>@GetRoleLabel(context.User)</small>
                        </span>
                        <i class="fa-solid fa-angle-down user-menu-chevron"></i>
                    </summary>
                    <div class="header-dropdown-menu user-dropdown-menu">
                        <div class="user-dropdown-profile">
                            <span class="avatar avatar-large"><i class="fa-solid fa-user"></i></span>
                            <div>
                                <strong>@context.User.Identity?.Name</strong>
                                <small>@GetRoleLabel(context.User)</small>
                            </div>
                        </div>
                        <div class="user-dropdown-links">
                            <a href="/dashboard"><i class="fa-solid fa-gauge-high"></i><span>لوحة التحكم</span></a>
                            @if (HasRoute("/tasks/mine"))
                            {
                                <a href="/tasks/mine"><i class="fa-solid fa-list-check"></i><span>مهامي</span></a>
                            }
                            @if (HasRoute("/notifications/manage"))
                            {
                                <a href="/notifications/manage"><i class="fa-solid fa-bell"></i><span>التنبيهات</span></a>
                            }
                        </div>
                        <div class="user-dropdown-footer">
                            <a class="logout-link" href="/logout"><i class="fa-solid fa-arrow-right-from-bracket"></i><span>تسجيل الخروج</span></a>
                        </div>
                    </div>
                </details>
            </Authorized>
        </AuthorizeView>
    </div>
</header>

<button class="menu-overlay" type="button" data-shell-close aria-label="إغلاق القائمة"></button>
<aside id="side-navigation" class="menu-container" aria-label="الشريط الجانبي">
    <div class="logo">
        <div class="logo-card">
            <span class="sidebar-brand-mark"><i class="fa-solid fa-building-columns"></i></span>
            <span class="sidebar-brand-copy">
                <strong>مؤسسة سعيد مبارك الشهراني</strong>
                <span>للتجارة</span>
            </span>
            <small>منصة الخدمات الإدارية المتكاملة</small>
        </div>
    </div>

    <nav id="side-menu" class="side-panel" aria-label="التنقل الرئيسي">
        @if (navigation.Count == 0)
        {
            <details open>
                <summary><i class="fa-solid fa-layer-group"></i><span>خطة خدمات النظام</span><i class="fa-solid fa-angle-down angle"></i></summary>
                <a href="/system/modules">تجهيز خريطة النظام</a>
            </details>
        }
        else
        {
            @foreach (var module in navigation)
            {
                <details open="@ModuleContainsCurrentRoute(module)">
                    <summary>
                        <i class="@SidebarIcon(module.IconCss)"></i>
                        <span>@module.NameAr</span>
                        <i class="fa-solid fa-angle-down angle"></i>
                    </summary>
                    @foreach (var group in module.Groups)
                    {
                        <div class="side-separator">@group.NameAr</div>
                        @foreach (var navPage in group.Pages)
                        {
                            <a class="@(IsCurrentRoute(navPage.Route) ? "active" : string.Empty)" href="@navPage.Route" title="@navPage.OriginalHref" data-shell-close>
                                @navPage.NameAr
                                @if (navPage.Status != "Implemented")
                                {
                                    <small>مخطط</small>
                                }
                            </a>
                        }
                    }
                </details>
            }
        }
    </nav>
</aside>

<main class="page-container-legacy">
    @if (!layoutReady)
    {
        <section class="panel"><div class="panel-body">جارٍ تحميل خدمات النظام...</div></section>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(layoutWarning))
        {
            <section class="system-warning" role="status">
                <i class="fa-solid fa-circle-info"></i>
                <span>@layoutWarning</span>
            </section>
        }
        <CatalogRouteGuard>
            @Body
        </CatalogRouteGuard>
    }
</main>

@code {
    private List<SystemNavigationModuleResponse> navigation = [];
    private int unreadNotificationCount;
    private bool layoutReady;
    private string? layoutWarning;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            navigation = await Catalog.GetNavigationAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load the shared system navigation.");
            navigation = [];
            layoutWarning = "تعذر تحميل قائمة الخدمات حالياً، لكن يمكنك متابعة استخدام الصفحة المفتوحة.";
        }

        try
        {
            unreadNotificationCount = await Messaging.GetUnreadNotificationCountAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Failed to load the unread notification count.");
            unreadNotificationCount = 0;
            layoutWarning ??= "تعذر تحديث بعض بيانات الشريط العلوي، ويمكنك متابعة العمل بشكل طبيعي.";
        }

        layoutReady = true;
    }

    private static string SidebarIcon(string? iconCss)
    {
        if (string.IsNullOrWhiteSpace(iconCss))
            return "fa-solid fa-folder-open";

        return iconCss
            .Replace("menu-icon", string.Empty, StringComparison.OrdinalIgnoreCase)
            .Replace("fal", "fa-solid", StringComparison.OrdinalIgnoreCase)
            .Trim();
    }

    private bool IsCurrentRoute(string route) => string.Equals(Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/'), route.TrimStart('/').TrimEnd('/'), StringComparison.OrdinalIgnoreCase);
    private bool HasRoute(string route) => navigation.SelectMany(x => x.Groups).SelectMany(x => x.Pages).Any(x => string.Equals(x.Route, route, StringComparison.OrdinalIgnoreCase));
    private bool ModuleContainsCurrentRoute(SystemNavigationModuleResponse module) => module.Groups.SelectMany(x => x.Pages).Any(x => IsCurrentRoute(x.Route));
    private static string GetRoleLabel(System.Security.Claims.ClaimsPrincipal user) =>
        user.IsInRole("Admin") ? "مدير النظام" :
        user.IsInRole("Chairman") ? "رئيس مجلس الإدارة" :
        user.IsInRole("Secretary") ? "أمين النظام" :
        user.IsInRole("Member") ? "عضو" : "مستخدم النظام";
}
